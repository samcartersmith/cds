{
  "name": "@cbhq/script-utils",
  "version": "0.0.0",
  "private": true,
  "description": "Script utils",
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/script-utils"
  },
  "keywords": [
    "script",
    "utils"
  ],
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "peerDependencies": {
    "@cbhq/eslint-plugin": "^1.26.3",
    "@cbhq/mono-tasks": "^0.9.12",
    "lodash": "^4.17.21",
    "prettier": "^2.8.3"
  },
  "dependencies": {
    "type-fest": "^2.19.0"
  },
  "types": "./dts/index.d.ts",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dts/*.d.ts",
      "node": "./lib/*.js",
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./dts/index.d.ts",
      "node": "./lib/index.js",
      "default": "./lib/index.js"
    }
  }
}
