{
  "name": "@cbhq/cds-tasks",
  "version": "0.0.0",
  "description": "CDS nx tasks",
  "keywords": [],
  "executors": "./executor.json",
  "packemon": {
    "format": "lib",
    "platform": "node",
    "externals": [
      "@nrwl/devkit"
    ]
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "execa": "^5.1.1",
    "fast-glob": "^3.2.11",
    "lodash": "^4.17.21"
  },
  "types": "./dts/index.d.ts",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dts/*.d.ts",
      "node": "./lib/*.js",
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./dts/index.d.ts",
      "node": "./lib/index.js",
      "default": "./lib/index.js"
    }
  }
}
