{
  "name": "cds-tasks",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cds-tasks",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@cbhq/mono-tasks:build-package",
      "outputs": [
        "{projectRoot}/dts",
        "{projectRoot}/lib"
      ]
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "report-disabled-eslint-rules": {
      "executor": "@cbhq/prevent-eslint-disable:report"
    },
    "watch": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/figma-tasks",
        "command": "packemon watch --quiet --loadConfigs"
      }
    }
  }
}
