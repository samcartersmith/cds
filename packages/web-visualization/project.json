{
  "name": "web-visualization",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/web-visualization",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@cbhq/cds-tasks:build-package",
      "outputs": [
        "{workspaceRoot}/.nx/dist/packages/web-visualization"
      ],
      "options": {
        "destinationDir": ".nx/dist/packages/web-visualization",
        "srcDir": "src",
        "babelConfig": "./packages/web-visualization/babel.config.js",
        "babelExtensions": [
          ".ts",
          ".tsx"
        ],
        "staticFilesToCopy": [
          "package.json",
          "README.md",
          "CHANGELOG.md"
        ],
        "babelIgnore": [
          "**/*.js",
          "**/*.test.ts",
          "**/*.test.tsx",
          "**/*.stories.tsx"
        ],
        "typescriptConfig": "packages/web-visualization/tsconfig.build.json"
      }
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "report-disabled-eslint-rules": {
      "executor": "@cbhq/prevent-eslint-disable:report"
    },
    "danger": {
      "executor": "@cbhq/mono-tasks:danger",
      "options": {
        "dangerfile": "libs/dangerfiles/dangerfile.ts"
      }
    },
    "danger-test": {
      "executor": "@cbhq/mono-tasks:danger",
      "options": {
        "dangerfile": "libs/dangerfiles/dangerfile-coverage.ts",
        "timeoutSeconds": 30
      }
    }
  }
}
