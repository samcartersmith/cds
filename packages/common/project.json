{
  "name": "common",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/common",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "@cbhq/mono-tasks:lint-styles"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "export-package-version": {
      "executor": "@cbhq/cds-tasks:export-package-version"
    },
    "build": {
      "executor": "@cbhq/cds-tasks:build-package",
      "outputs": [
        "{workspaceRoot}/.nx/dist/packages/common"
      ],
      "options": {
        "destinationDir": ".nx/dist/packages/common",
        "staticFilesToIgnore": [
          "jest.config.js",
          "tsconfig.json",
          "tsconfig.build.json",
          "project.json"
        ],
        "babelConfig": "./babel.config.js",
        "babelExtensions": [
          ".ts",
          ".tsx"
        ],
        "babelIgnore": [
          "**/*.js",
          "**/*.test.ts",
          "**/*.test.tsx"
        ],
        "typescriptConfig": "packages/common/tsconfig.build.json"
      }
    },
    "danger": {
      "executor": "@cbhq/mono-tasks:danger",
      "options": {
        "dangerfile": "libs/dangerfiles/dangerfile.ts"
      }
    },
    "danger-test": {
      "executor": "@cbhq/mono-tasks:danger",
      "options": {
        "dangerfile": "libs/dangerfiles/dangerfile-coverage.ts",
        "timeoutSeconds": 30
      }
    }
  }
}
