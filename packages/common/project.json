{
  "name": "common",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/common/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "command": "rm -rf esm && babel ./src --out-dir esm --extensions .ts,.tsx,.js,.jsx --copy-files --no-copy-ignored"
    },
    "build-mcp": {
      "dependsOn": [
        "docs:build"
      ],
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "rm -rf mcp-docs",
          "nx run docs:build-llm-docs ./packages/common/mcp-docs",
          "chmod +x esm/mcp/server.js esm/mcp/setup.js"
        ],
        "cwd": "{projectRoot}",
        "parallel": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "{projectRoot}/jest.config.js"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "dev",
      "configurations": {
        "dev": {
          "commands": [
            "tsc --build --pretty --verbose",
            "prettier ./dts --write --loglevel warn"
          ],
          "parallel": false
        },
        "prod": {
          "commands": [
            "tsc --build ./tsconfig.build.json --pretty --verbose",
            "prettier ./dts --write --loglevel warn"
          ],
          "parallel": false
        }
      }
    },
    "inspect-mcp": {
      "dependsOn": [
        "build-mcp"
      ],
      "command": "npx @modelcontextprotocol/inspector npx tsx src/mcp/server.ts"
    }
  }
}
