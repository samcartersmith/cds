{
  "extends": ["../../.eslintrc.json"],
  "ignorePatterns": ["!**/*"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": ["@cbhq/cds-common"],
            "patterns": ["@cbhq/cds-common/*"]
          }
        ],
        "no-process-env": "error"
      },
      "parserOptions": {
        "project": ["packages/common/tsconfig.*?.json"]
      }
    }
  ]
}
