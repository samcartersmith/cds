{
  "name": "lottie-files",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/lottie-files",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "build": {
      "executor": "@cbhq/cds-tasks:build-package",
      "outputs": [
        "{workspaceRoot}/.nx/dist/packages/lottie-files"
      ],
      "options": {
        "destinationDir": ".nx/dist/packages/lottie-files",
        "staticFilesToIgnore": [
          "tsconfig.json",
          "tsconfig.build.json",
          "project.json"
        ],
        "babelConfig": "./babel.config.js",
        "babelExtensions": [
          ".ts",
          ".tsx"
        ],
        "babelIgnore": [
          "**/*.js",
          "**/*.test.ts",
          "**/*.test.tsx"
        ],
        "typescriptConfig": "packages/lottie-files/tsconfig.build.json"
      }
    }
  }
}
