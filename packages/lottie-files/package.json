{
  "name": "@cbhq/cds-lottie-files",
  "version": "0.2.20",
  "description": "Coinbase Design System - Lottie Files",
  "repository": "git@github.cbhq.net:jonathan-rossi/design-system.git",
  "type": "commonjs",
  "keywords": [
    "cds",
    "design system",
    "lottie files",
    "animations"
  ],
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "types": "./index.d.ts",
  "main": "./index.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "node": "./lib/*.js",
      "types": "./dts/*.d.ts"
    },
    ".": {
      "node": "./lib/index.js",
      "types": "./dts/index.d.ts"
    }
  },
  "files": [
    "dts/**/*.d.ts",
    "lib/**/*.{js,map}",
    "src/**/*.{ts,tsx,json}"
  ]
}
