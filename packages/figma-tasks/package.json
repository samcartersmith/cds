  },
  "dependencies": {
    "@cbhq/d3": "workspace:^",
    "@cbhq/figma-api": "workspace:^",
    "@cbhq/mono-tasks": "^0.10.1",
    "@cbhq/script-utils": "workspace:^",
    "@types/svgo": "^2.6.4",
    "lodash": "^4.17.21",
    "sharp": "^0.31.2",
    "svgo": "^3.0.2",
    "update-notifier": "^5.1.0",
    "webfont": "9.0.0"
  },
  "peerDependencies": {
    "@nrwl/devkit": ">=15.0.0"
  },
  "devDependencies": {
    "@types/sharp": "^0.31.0"
  }
