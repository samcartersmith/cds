{
  "name": "@cbhq/figma-tasks",
  "version": "0.0.0",
  "private": true,
  "description": "Figma nx tasks",
  "keywords": [
    "figma",
    "nx"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/figma-tasks"
  },
  "packemon": {
    "api": "private",
    "format": "lib",
    "platform": "node"
  },
  "executors": "./executors.json",
  "main": "./lib/index.js",
