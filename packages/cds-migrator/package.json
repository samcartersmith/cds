{
  "name": "@cbhq/cds-migrator",
  "version": "0.1.5",
  "description": "Codemod transformations to help upgrade your CDS codebase",
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/cds-migrator"
  },
  "keywords": [
    "cds",
    "cli",
    "codemod"
  ],
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "fast-glob": "^3.2.11",
    "ts-morph": "^17.0.1",
    "update-notifier": "^5.1.0"
  },
  "peerDependencies": {
    "@nrwl/devkit": ">=15.0.0"
  },
  "generators": "./generators.json",
  "types": "./lib/index.d.ts",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./lib/*.d.ts",
      "node": {
        "types": "./lib/*.d.ts",
        "default": "./lib/*.js"
      },
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./lib/index.d.ts",
      "node": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "default": "./lib/index.js"
    }
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.0"
  }
}
