{
  "name": "cds-migrator",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cds-migrator/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@cbhq/mono-tasks:build-package",
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "{projectRoot}/assets",
        "{projectRoot}/dts",
        "{projectRoot}/lib"
      ]
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "watch": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build"
      ],
      "options": {
        "cwd": "packages/cds-migrator",
        "commands": [
          "packemon watch --quiet --loadConfigs"
        ]
      }
    }
  }
}
