{
  "name": "@cbhq/ui-mobile-playground",
  "version": "1.0.1",
  "description": "Mobile UI Components in a Playground",
  "keywords": [
    "playground"
  ],
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "peerDependencies": {
    "@cbhq/cds-common": "workspace:^",
    "@cbhq/cds-mobile": "workspace:^",
    "@cbhq/cds-mobile-visualization": "workspace:^",
    "@react-navigation/native": "^6.1.6",
    "@react-navigation/stack": "^6.3.16",
    "react": "18.2.0",
    "react-native": ">=0.68.2",
    "react-native-safe-area-context": "^4.5.0"
  },
  "dependencies": {
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@react-navigation/native": "^6.1.6",
    "@react-navigation/stack": "^6.3.16",
    "@types/react": "18.0.28",
    "detox": "^20.5.0"
  },
  "types": "./lib/index.d.ts",
  "main": "./lib/index.js",
  "routes": "./lib/routes.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./lib/*.d.ts",
      "node": {
        "types": "./lib/*.d.ts",
        "default": "./lib/*.js"
      },
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./lib/index.d.ts",
      "node": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "default": "./lib/index.js"
    }
  },
  "files": [
    "dts/**/*.d.ts",
    "lib/**/*.{js,map}",
    "src/**/*.{ts,tsx}",
    "CHANGELOG.md",
    "README.md"
  ]
}
