{
  "name": "@cbhq/docusaurus-preset",
  "version": "0.0.1",
  "description": "CDS Docusaurus preset",
  "private": true,
  "keywords": [
    "docusaurus",
    "preset"
  ],
  "repository": "git@github.cbhq.net:frontend/cds.git",
  "authors": "Coinbase",
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "dependencies": {
    "@cbhq/docusaurus-plugin-docgen": "workspace:*",
    "@cbhq/docusaurus-plugin-kbar": "workspace:*",
    "@cbhq/docusaurus-theme": "workspace:*",
    "@docusaurus/preset-classic": "2.0.0-beta.18",
    "@docusaurus/theme-live-codeblock": "2.0.0-beta.18",
    "type-fest": "1.2.0"
  },
  "devDependencies": {
    "@docusaurus/types": "2.0.0-beta.18"
  },
  "peerDependencies": {
    "@cbhq/cds-common": "workspace:*"
  },
  "types": "./dts/index.d.ts",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dts/*.d.ts",
      "node": "./lib/*.js",
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./dts/index.d.ts",
      "node": "./lib/index.js",
      "default": "./lib/index.js"
    }
  }
}
