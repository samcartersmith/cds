{
  "name": "@cbhq/cds-migrator",
  "version": "0.2.44",
  "description": "Codemod transformations to help upgrade your CDS codebase",
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/migrator"
  },
  "type": "commonjs",
  "bin": {
    "cds-migrator-codemod": "./cjs/cli/codemod.js",
    "cds-migrator-interactive": "./cjs/cli/interactive-codemod.js",
    "cds-migrator-v8-adoption-stats": "./cjs/cli/v8-adoption-stats.js"
  },
  "main": "./cjs/index.js",
  "types": "./dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dts/index.d.ts",
      "default": "./cjs/index.js"
    },
    "./migrations/update-8-0-0-incremental-jscodeshift": {
      "types": "./dts/migrations/update-8-0-0-incremental-jscodeshift/index.d.ts",
      "default": "./cjs/migrations/update-8-0-0-incremental-jscodeshift/index.js"
    },
    "./migrations/update-8-0-0-jscodeshift": {
      "types": "./dts/migrations/update-8-0-0-jscodeshift/index.d.ts",
      "default": "./cjs/migrations/update-8-0-0-jscodeshift/index.js"
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "default": "./cjs/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "cjs",
    "dts",
    "CHANGELOG"
  ],
  "peerDependencies": {
    "@nx/devkit": ">=15.0.0",
    "jscodeshift": ">=0.14.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "fast-glob": "^3.2.11",
    "ts-morph": "^19.0.0",
    "update-notifier": "^5.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@types/cli-progress": "^3.11.0",
    "@types/jscodeshift": "^17.3.0",
    "@types/semver": "^7",
    "@types/update-notifier": "^5.1.0",
    "jscodeshift": "^0.15.1",
    "semver": "^7.5.4"
  }
}
