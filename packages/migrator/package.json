{
  "name": "@cbhq/cds-migrator",
  "version": "0.2.2",
  "description": "Codemod transformations to help upgrade your CDS codebase",
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/migrator"
  },
  "generators": "./generators.json",
  "type": "commonjs",
  "main": "./cjs/index.js",
  "types": "./dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dts/index.d.ts",
      "default": "./cjs/index.js"
    },
    "./migrations/banner": {
      "types": "./dts/migrations/banner/index.d.ts",
      "default": "./cjs/migrations/banner/index.js"
    },
    "./migrations/gap": {
      "types": "./dts/migrations/gap/index.d.ts",
      "default": "./cjs/migrations/gap/index.js"
    },
    "./migrations/gondolin": {
      "types": "./dts/migrations/gondolin/index.d.ts",
      "default": "./cjs/migrations/gondolin/index.js"
    },
    "./migrations/revert-decomp": {
      "types": "./dts/migrations/revert-decomp/index.d.ts",
      "default": "./cjs/migrations/revert-decomp/index.js"
    },
    "./migrations/update-4-0-0": {
      "types": "./dts/migrations/update-4-0-0/index.d.ts",
      "default": "./cjs/migrations/update-4-0-0/index.js"
    },
    "./migrations/update-5-0-0": {
      "types": "./dts/migrations/update-5-0-0/index.d.ts",
      "default": "./cjs/migrations/update-5-0-0/index.js"
    },
    "./migrations/update-6-0-0": {
      "types": "./dts/migrations/update-6-0-0/index.d.ts",
      "default": "./cjs/migrations/update-6-0-0/index.js"
    },
    "./migrations/update-decomp": {
      "types": "./dts/migrations/update-decomp/index.d.ts",
      "default": "./cjs/migrations/update-decomp/index.js"
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "default": "./cjs/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "cjs",
    "dts",
    "CHANGELOG"
  ],
  "peerDependencies": {
    "@nx/devkit": ">=15.0.0"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "fast-glob": "^3.2.11",
    "ts-morph": "^19.0.0",
    "update-notifier": "^5.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@types/cli-progress": "^3.11.0",
    "@types/semver": "^7",
    "semver": "^7.5.4"
  }
}
