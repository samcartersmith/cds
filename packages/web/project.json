{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/web",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "@cbhq/mono-tasks:lint-styles"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "build": {
      "executor": "@cbhq/cds-tools:build-package",
      "outputs": [
        "{workspaceRoot}/.nx/dist/packages/web"
      ],
      "options": {
        "destinationDir": ".nx/dist/packages/web",
        "staticFilesToIgnore": [
          "babel.config.js",
          "jest.config.js",
          "linaria.config.js",
          "tsconfig.json",
          "tsconfig.build.json",
          "tsconfig.build-esm.json",
          "project.json"
        ],
        "babelConfig": "./packages/web/babel.config.js",
        "babelExtensions": [
          ".ts",
          ".tsx"
        ],
        "babelIgnore": [
          "**/*.js",
          "**/*.test.ts",
          "**/*.test.tsx",
          "**/*.stories.tsx",
          "storybook-decorators"
        ],
        "typescriptConfig": "packages/web/tsconfig.build.json"
      },
      "dependsOn": [
        "^build",
        "build-esm"
      ]
    },
    "build-esm": {
      "executor": "@cbhq/cds-tools:build-package-esm",
      "outputs": [
        "{workspaceRoot}/.nx/dist/packages/web-esm"
      ],
      "options": {
        "destinationDir": ".nx/dist/packages/web-esm",
        "staticFilesToIgnore": [
          "babel.config.js",
          "jest.config.js",
          "linaria.config.js",
          "tsconfig.json",
          "tsconfig.build.json",
          "tsconfig.build-esm.json",
          "project.json"
        ],
        "babelConfig": "./packages/web/babel.config.js",
        "babelExtensions": [
          ".ts",
          ".tsx"
        ],
        "babelIgnore": [
          "**/*.js",
          "**/*.test.ts",
          "**/*.test.tsx",
          "**/*.stories.tsx",
          "storybook-decorators"
        ],
        "typescriptConfig": "packages/web/tsconfig.build-esm.json",
        "iconsOutputDir": "packages/icons/fonts/web",
        "fontsOutputDir": "packages/fonts",
        "maxFileSizeInKb": 115
      },
      "dependsOn": [
        "^build"
      ]
    },
    "build-css": {
      "executor": "@cbhq/cds-tools:build-css",
      "outputs": [
        "{workspaceRoot}/.nx/dist/cloud/css"
      ],
      "options": {
        "iconsOutputDir": "packages/icons/fonts/web",
        "fontsOutputDir": ".nx/dist/packages/fonts",
        "webOutputDir": ".nx/dist/packages/web",
        "outputDir": ".nx/dist/cloud/css"
      },
      "dependsOn": [
        "build"
      ]
    },
    "danger": {
      "executor": "@cbhq/mono-tasks:danger",
      "options": {
        "dangerfile": "libs/dangerfiles/dangerfile.ts"
      }
    },
    "danger-test": {
      "executor": "@cbhq/mono-tasks:danger",
      "options": {
        "dangerfile": "libs/dangerfiles/dangerfile-coverage.ts",
        "timeoutSeconds": 30
      }
    }
  }
}
