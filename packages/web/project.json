{
  "root": "packages/web",
  "sourceRoot": "packages/web",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "@cbhq/cds-tools:lint-styles"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/cds-tools:typecheck"
    },
    "build": {
      "executor": "@cbhq/cds-tools:build-package",
      "options": {
        "destinationDir": ".nx/dist/packages/web",
        "staticFilesToIgnore": [
          "babel.build.config.js",
          "babel.config.js",
          "jest.config.js",
          "linaria.config.js",
          "tsconfig.json",
          "tsconfig.build.json",
          "tsconfig.build-esm.json",
          "project.json"
        ],
        "babelConfig": "./packages/web/babel.build.config.js",
        "babelExtensions": [".ts", ".tsx"],
        "babelIgnore": [
          "**/*.js",
          "**/*.test.ts",
          "**/*.test.tsx",
          "**/*.stories.tsx",
          "storybook-decorators"
        ],
        "typescriptConfig": "packages/web/tsconfig.build.json"
      },
      "dependsOn": [
        {
          "target": "build-esm",
          "projects": "self"
        }
      ]
    },
    "build-esm": {
      "executor": "@cbhq/cds-tools:build-package-esm",
      "options": {
        "destinationDir": ".nx/dist/packages/web-esm",
        "staticFilesToIgnore": [
          "babel.build.config.js",
          "babel.config.js",
          "jest.config.js",
          "linaria.config.js",
          "tsconfig.json",
          "tsconfig.build.json",
          "tsconfig.build-esm.json",
          "project.json"
        ],
        "babelConfig": "./packages/web/babel.build.config.js",
        "babelExtensions": [".ts", ".tsx"],
        "babelIgnore": [
          "**/*.js",
          "**/*.test.ts",
          "**/*.test.tsx",
          "**/*.stories.tsx",
          "storybook-decorators"
        ],
        "typescriptConfig": "packages/web/tsconfig.build-esm.json",
        "fontsOutputDir": "packages/fonts",
        "maxFileSizeInKb": 115
      },
      "dependsOn": [
        {
          "target": "build",
          "projects": "dependencies"
        }
      ]
    },
    "run-percy": {
      "executor": "@cbhq/cds-tools:run-conditional",
      "options": {
        "triggerProjects": ["web", "common", "utils", "fonts", "lottie-files"],
        "target": "storybook:percy"
      }
    },
    "build-css": {
      "executor": "@cbhq/cds-tools:build-css",
      "options": {
        "fontsOutputDir": ".nx/dist/packages/fonts",
        "webOutputDir": ".nx/dist/packages/web",
        "outputDir": ".nx/dist/cloud/css"
      }
    }
  }
}
