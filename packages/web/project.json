{
  "root": "packages/web",
  "sourceRoot": "packages/web",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "start-storybook": {
      "executor": "@cbhq/mono-tasks:start-storybook"
    },
    "build-storybook": {
      "executor": "@cbhq/mono-tasks:build-storybook"
    },
    "build-package": {
      "executor": "./tools/executors/build-package:build-package",
      "options": {
        "destinationDir": ".nx/dist/packages/web",
        "staticFiles": [
          {
            "source": "packages/web/package.json",
            "dest": "package.json"
          },
          "packages/web/CHANGELOG.md",
          "packages/web/README.md"
        ],
        "babelConfig": "./packages/web/babel.build.config.js",
        "babelExtensions": [
          ".ts",
          ".tsx"
        ],
        "babelIgnore": [
          "**/*.js",
          "**/*.test.ts",
          "**/*.test.tsx"
        ],
        "typescriptConfig": "packages/web/tsconfig.build.json"
      }
    }
  }
}
