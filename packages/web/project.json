{
  "name": "web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/web",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "@cbhq/mono-tasks:lint-styles"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "build": {
      "executor": "@cbhq/cds-tasks:build-package",
      "outputs": [
        "{workspaceRoot}/.nx/dist/packages/web"
      ],
      "options": {
        "destinationDir": ".nx/dist/packages/web",
        "staticFilesToIgnore": [
          "babel.config.js",
          "jest.config.js",
          "linaria.config.js",
          "tsconfig.json",
          "tsconfig.build.json",
          "project.json"
        ],
        "babelConfig": "./packages/web/babel.config.js",
        "babelExtensions": [
          ".ts",
          ".tsx"
        ],
        "babelIgnore": [
          "**/*.js",
          "**/*.test.ts",
          "**/*.test.tsx",
          "**/*.stories.tsx",
          "storybook-decorators"
        ],
        "typescriptConfig": "packages/web/tsconfig.build.json"
      },
      "dependsOn": [
        "^build"
      ]
    },
    "build-css": {
      "executor": "@cbhq/cds-tasks:build-css",
      "inputs": [
        "{workspaceRoot}/packages/icons/fonts/web/**/*",
        "{workspaceRoot}/.nx/dist/packages/fonts/**/*",
        "{workspaceRoot}/.nx/dist/packages/web/**/*",
        "production"
      ],
      "outputs": [
        "{workspaceRoot}/.nx/dist/cloud/css"
      ],
      "options": {
        "iconsOutputDir": "packages/icons/fonts/web",
        "fontsOutputDir": ".nx/dist/packages/fonts",
        "webOutputDir": ".nx/dist/packages/web",
        "outputDir": ".nx/dist/cloud/css"
      },
      "dependsOn": [
        "build"
      ]
    },
    "danger": {
      "executor": "@cbhq/mono-tasks:danger",
      "options": {
        "dangerfile": "libs/dangerfiles/dangerfile.ts"
      }
    },
    "danger-test": {
      "executor": "@cbhq/mono-tasks:danger",
      "options": {
        "dangerfile": "libs/dangerfiles/dangerfile-coverage.ts",
        "timeoutSeconds": 30
      }
    },
    "perf-test-clean": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "jest --clearCache"
        ]
      }
    },
    "perf-test": {
      "executor": "@cbhq/mono-tasks:run-script",
      "outputs": [
        ".reassure"
      ],
      "options": {
        "script": "../../node_modules/.bin/reassure",
        "root": "/packages/web"
      },
      "env": {
        "NX_BAN_LOGS": false,
        "TEST_RUNNER_PATH": "../../node_modules/.bin/jest",
        "TEST_RUNNER_ARGS": "--detectOpenHandles --runInBand --forceExit --testMatch \"<rootDir>/**/(*.)perf-test.[jt]s?(x)\"",
        "TARGET_ENV": "perf_test_js"
      },
      "dependsOn": [
        "^build",
        "perf-test-clean"
      ]
    }
  }
}
