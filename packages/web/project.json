{
  "root": "packages/web",
  "sourceRoot": "packages/web",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "./tools/executors/lint-styles:lint-styles"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "./tools/executors/typecheck:typecheck"
    },
    "build": {
      "executor": "./tools/executors/build-package:build-package",
      "options": {
        "destinationDir": ".nx/dist/packages/web",
        "staticFilesToIgnore": [
          "babel.build.config.js",
          "babel.config.js",
          "jest.config.js",
          "linaria.config.js",
          "tsconfig.json",
          "tsconfig.build.json",
          "project.json"
        ],
        "babelConfig": "./packages/web/babel.build.config.js",
        "babelExtensions": [".ts", ".tsx"],
        "babelIgnore": ["**/*.js", "**/*.test.ts", "**/*.test.tsx", "**/*.stories.tsx"],
        "typescriptConfig": "packages/web/tsconfig.build.json"
      }
    },
    "build-css": {
      "executor": "./tools/executors/build-css:build-css",
      "options": {
        "fontsOutputDir": ".nx/dist/packages/fonts",
        "webOutputDir": ".nx/dist/packages/web",
        "outputDir": ".nx/dist/cloud/css"
      }
    }
  }
}
