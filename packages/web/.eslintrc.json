{
  "extends": ["../../.eslintrc.js"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {
        "import/no-extraneous-dependencies": [
          "error",
          {
            "devDependencies": true
          }
        ]
      }
    },
    {
      "files": ["*.test.ts", "*.test.tsx", "*.stories.ts", "*.stories.tsx"],
      "rules": {
        "import/no-extraneous-dependencies": 0
      }
    }
  ]
}
