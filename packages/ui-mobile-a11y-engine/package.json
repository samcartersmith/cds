{
  "name": "@cbhq/ui-mobile-a11y-engine",
  "type": "commonjs",
  "version": "0.0.0",
  "description": "Make accessibility-related assertions on React Native code using React Test Renderer",
  "types": "./dts/index.d.ts",
  "main": "./cjs/index.cjs",
  "source": "src",
  "files": [
    "src",
    "cjs",
    "dts",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "react-native",
    "mobile",
    "jest",
    "testing",
    "testing-library",
    "a11y",
    "accessibility",
    "ios",
    "android"
  ],
  "packemon": {
    "format": "cjs",
    "platform": "node"
  },
  "executors": "./executors.json",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dts/index.d.ts",
      "node": {
        "import": "./cjs/index-wrapper.mjs",
        "require": "./cjs/index.cjs"
      }
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "node": {
        "require": "./cjs/*.cjs"
      }
    }
  },
  "repository": "git@github.cbhq.net:frontend/cds.git",
  "devDependencies": {
    "@react-native-community/slider": "4.2.0",
    "@testing-library/jest-native": "4.0.4",
    "@testing-library/react-native": "9.0.0",
    "@types/lodash.groupby": "4.6.6",
    "@types/react": "^17.0.3",
    "@types/react-native": "^0.68.2",
    "@types/react-test-renderer": "17.0.1",
    "react": "17.0.2",
    "react-native": "^0.68.2"
  },
  "peerDependencies": {
    "@cbhq/mono-tasks": "^0.4.21",
    "react": "*",
    "react-native": "*",
    "typescript": "~4.7.2"
  },
  "dependencies": {
    "execa": "^5.1.1",
    "jest-matcher-utils": "^24.0.0",
    "lodash.groupby": "^4.6.0",
    "react-test-renderer": "^17.0.2"
  }
}
