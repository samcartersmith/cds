{
  "root": "packages/fonts",
  "sourceRoot": "packages/fonts",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@cbhq/cds-tools:build-package",
      "options": {
        "destinationDir": ".nx/dist/packages/fonts",
        "staticFilesToIgnore": ["tsconfig.json", "tsconfig.build.json", "project.json"],
        "babelConfig": "./babel.build.config.js",
        "babelExtensions": [".ts", ".tsx"],
        "babelIgnore": ["**/*.js", "**/*.test.ts", "**/*.test.tsx"],
        "typescriptConfig": "packages/fonts/tsconfig.build.json"
      }
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "@cbhq/cds-tools:lint-styles"
    },
    "typecheck": {
      "executor": "@cbhq/cds-tools:typecheck"
    }
  }
}
