{
  "name": "fonts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/fonts",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@cbhq/cds-tasks:build-package",
      "outputs": ["{workspaceRoot}/.nx/dist/packages/fonts"],
      "options": {
        "destinationDir": ".nx/dist/packages/fonts",
        "staticFilesToIgnore": ["tsconfig.json", "tsconfig.build.json", "project.json"],
        "babelConfig": "./babel.config.js",
        "babelExtensions": [".ts", ".tsx"],
        "babelIgnore": ["**/*.js", "**/*.test.ts", "**/*.test.tsx"],
        "typescriptConfig": "packages/fonts/tsconfig.build.json"
      }
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "@cbhq/mono-tasks:lint-styles"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    }
  }
}
