{
  "name": "@cbhq/docusaurus-plugin-kbar",
  "version": "0.0.1",
  "private": true,
  "description": "Docusaurus plugin for command bar",
  "keywords": [
    "docusaurus",
    "plugin",
    "command bar"
  ],
  "repository": "git@github.cbhq.net:frontend/cds.git",
  "authors": "Coinbase",
  "dependencies": {
    "@docusaurus/logger": "2.0.0-beta.20",
    "@docusaurus/plugin-content-docs": "2.0.0-beta.18",
    "@docusaurus/types": "2.0.0-beta.18",
    "kbar": "^0.1.0-beta.35",
    "lodash": "^4.17.21",
    "type-fest": "1.2.0"
  },
  "peerDependencies": {
    "@cbhq/cds-common": "workspace:*"
  },
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "types": "./dts/index.d.ts",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dts/*.d.ts",
      "node": "./lib/*.js",
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./dts/index.d.ts",
      "node": "./lib/index.js",
      "default": "./lib/index.js"
    }
  }
}
