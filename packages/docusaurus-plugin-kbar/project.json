{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/docusaurus-plugin-kbar",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@cbhq/cds-tools:build-docusaurus-plugin",
      "outputs": ["{projectRoot}/lib"]
    },
    "watch": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/docusaurus-plugin-kbar",
        "commands": ["yarn docusaurus-plugin watch"]
      }
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    }
  }
}
