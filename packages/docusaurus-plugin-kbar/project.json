{
  "name": "docusaurus-plugin-kbar",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/docusaurus-plugin-kbar/src",
  "projectType": "library",
  "targets": {
    "watch": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/docusaurus-plugin-kbar",
        "commands": ["packemon watch --quiet --loadConfigs"]
      }
    },
    "build": {
      "executor": "@cbhq/mono-tasks:build-package",
      "outputs": ["{projectRoot}/dts", "{projectRoot}/lib"]
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    }
  }
}
