{
  "name": "@cbhq/ui-mobile-visreg",
  "version": "1.2.0",
  "description": "Visreg Helpers",
  "keywords": [
    "visreg",
    "playground",
    "ci",
    "percy",
    "detox"
  ],
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "dependencies": {
    "@cbhq/detox-utils": "^0.5.0",
    "@percy/cli": "^1.26.1",
    "@percy/client": "^1.26.1",
    "@percy/sdk-utils": "^1.26.1",
    "@percy/storybook": "^4.3.6",
    "lodash": "^4.17.21"
  },
  "peerDependencies": {
    "@cbhq/cds-mobile": "workspace:^",
    "@cbhq/cds-mobile-visualization": "workspace:^",
    "detox": "^20.5.0"
  },
  "devDependencies": {
    "detox": "^20.5.0"
  },
  "types": "./lib/index.d.ts",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./lib/*.d.ts",
      "node": {
        "types": "./lib/*.d.ts",
        "default": "./lib/*.js"
      },
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./lib/index.d.ts",
      "node": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "default": "./lib/index.js"
    }
  },
  "files": [
    "dts/**/*.d.ts",
    "lib/**/*.{js,map,d.ts}",
    "src/**/*.{ts}",
    "CHANGELOG.md",
    "README.md"
  ]
}
