{
  "name": "@cbhq/ui-mobile-visreg",
  "version": "3.0.0",
  "description": "Visreg Helpers",
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/ui-mobile-visreg"
  },
  "type": "module",
  "main": "./esm/index.js",
  "types": "./dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dts/index.d.ts",
      "default": "./esm/index.js"
    },
    "./detox": {
      "types": "./dts/detox/index.d.ts",
      "default": "./esm/detox/index.js"
    },
    "./percy": {
      "types": "./dts/percy/index.d.ts",
      "default": "./esm/percy/index.js"
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "default": "./esm/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dts",
    "esm",
    "src",
    "CHANGELOG"
  ],
  "peerDependencies": {
    "@cbhq/cds-mobile": "workspace:^",
    "@cbhq/cds-mobile-visualization": "workspace:^",
    "detox": "^20.14.8"
  },
  "dependencies": {
    "@cbhq/detox-utils": "^0.5.1",
    "@percy/cli": "^1.30.1",
    "@percy/client": "^1.30.1",
    "@percy/sdk-utils": "^1.30.1",
    "@percy/storybook": "^4.3.6",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@cbhq/cds-mobile": "workspace:^",
    "@cbhq/cds-mobile-visualization": "workspace:^",
    "detox": "^20.14.8"
  }
}
