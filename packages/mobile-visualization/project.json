{
  "sourceRoot": "packages/mobile-visualization",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@cbhq/cds-tasks:build-package",
      "outputs": [
        "{workspaceRoot}/.nx/dist/packages/mobile-visualization"
      ],
      "options": {
        "srcDir": "src",
        "destinationDir": ".nx/dist/packages/mobile-visualization",
        "babelConfig": "./packages/mobile-visualization/babel.config.js",
        "babelExtensions": [
          ".ts",
          ".tsx"
        ],
        "staticFilesToCopy": [
          "package.json",
          "README.md",
          "CHANGELOG.md"
        ],
        "babelIgnore": [
          "**/*.js",
          "**/*.test.ts",
          "**/*.test.tsx"
        ],
        "typescriptConfig": "packages/mobile-visualization/tsconfig.build.json"
      }
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "report-disabled-eslint-rules": {
      "executor": "@cbhq/prevent-eslint-disable:report"
    }
  }
}
