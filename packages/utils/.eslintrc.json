{
  "extends": ["../../.eslintrc.json"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": ["@cbhq/cds-utils"],
            "patterns": ["@cbhq/cds-utils/*"]
          }
        ],
        "no-process-env": "error"
      },
      "parserOptions": {
        "project": "../../tsconfig.eslint.json"
      }
    }
  ]
}
