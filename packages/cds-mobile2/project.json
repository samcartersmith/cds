{
  "name": "cds-mobile2",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cds-mobile2/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "command": "rm -rf esm && babel ./src --out-dir esm --extensions .ts,.tsx,.js,.jsx --copy-files --no-copy-ignored"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "{projectRoot}/jest.config.js"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "dev",
      "configurations": {
        "dev": {
          "command": "tsc --build --pretty --verbose"
        },
        "prod": {
          "command": "tsc --build ./tsconfig.build.json --pretty --verbose"
        }
      }
    },
    "audit-a11y": {
      "executor": "@cbhq/ui-scorecard:audit-a11y",
      "dependsOn": [
        "test"
      ],
      "options": {
        "eventProjectName": "cds_mobile",
        "platform": "mobile"
      }
    },
    "publish-figma": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "figma connect publish --token $FIGMA_CODE_CONNECT_TOKEN"
        ],
        "cwd": "packages/cds-mobile2"
      }
    }
  }
}
