{
  "name": "icons",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/icons",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@cbhq/mono-tasks:build-package",
      "outputs": [
        "{projectRoot}/dts",
        "{projectRoot}/lib"
      ]
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "sync": {
      "executor": "@cbhq/figma-tasks:sync-icons",
      "dependsOn": [
        "^build"
      ],
      "options": {
        "figmaApiFileId": "tuc9LpASTO9mBrbg1tAdAl",
        "changelogFile": "./CHANGELOG.md",
        "manifestFile": "./src/__generated__/manifest.json",
        "generatedDirectory": "./src/__generated__",
        "generatedFontName": "CoinbaseIcons",
        "generatedFontFormats": [
          {
            "generatedFontFormat": "woff2",
            "generatedFontDirectory": "./font",
            "generatedCssDirectory": "./font",
            "generatedCssFileName": "icon-font",
            "hashed": true
          },
          {
            "generatedFontFormat": "ttf",
            "generatedFontDirectory": "./font"
          }
        ]
      }
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "watch": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "packages/icons",
        "commands": [
          "nx run figma-tasks:watch",
          "packemon watch --quiet --loadConfigs"
        ]
      }
    }
  }
}
