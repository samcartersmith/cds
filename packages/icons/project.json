{
  "name": "icons",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/icons/src",
  "projectType": "library",
  "targets": {
    "build": {
      "command": "rm -rf esm && babel ./src --out-dir esm --extensions .ts,.tsx,.js,.jsx --copy-files --no-copy-ignored"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "dev",
      "configurations": {
        "dev": {
          "command": "tsc --build --pretty --verbose"
        },
        "prod": {
          "command": "tsc --build ./tsconfig.build.json --pretty --verbose"
        }
      }
    },
    "typecheck2": {
      "command": "tsc --build ./tsconfig.build.json --pretty --verbose",
      "options": {
        "cwd": "packages/icons"
      }
    },
    "mobile-build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build"
      ],
      "options": {
        "command": "echo 'Building icons for mobile'"
      }
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "sync": {
      "executor": "@cbhq/figma-tasks:sync-icons",
      "dependsOn": [
        "^build"
      ],
      "options": {
        "figmaApiFileId": "tuc9LpASTO9mBrbg1tAdAl",
        "changelogFile": "./CHANGELOG.md",
        "manifestFile": "./src/__generated__/manifest.json",
        "generatedDirectory": "./src/__generated__",
        "generatedFontName": "CoinbaseIcons",
        "generatedFontFormats": [
          {
            "generatedFontFormat": "woff2",
            "generatedFontDirectory": "./src/fonts/web",
            "generatedCssDirectory": "./src/fonts/web",
            "generatedCssFileName": "icon-font",
            "hashed": true
          },
          {
            "generatedFontFormat": "ttf",
            "generatedFontDirectory": "./src/fonts/native"
          }
        ]
      }
    },
    "generate-stories": {
      "command": "tsx ./scripts/generateStories.ts",
      "dependsOn": [
        "^build"
      ],
      "options": {
        "cwd": "packages/icons"
      }
    },
    "release": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run icons:sync",
          "nx run icons:generate-stories"
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    }
  }
}
