{
  "name": "@cbhq/cds-icons",
  "version": "1.0.0",
  "description": "CDS icons",
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "cds",
    "icons"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/cds-icons"
  },
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "main": "./lib/index.js",
  "types": "./dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dts/index.d.ts",
      "node": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./fonts/web/icon-font.css": "./fonts/web/icon-font.css",
    "./fonts/web/*.woff2": "./fonts/web/*.woff2",
    "./fonts/native/*.ttf": "./fonts/native/*.ttf",
    "./*": {
      "types": "./dts/*.d.ts",
      "node": "./lib/*.js",
      "default": "./lib/*.js"
    }
  },
  "devDependencies": {
    "@cbhq/figma-tasks": "workspace:^"
  }
}
