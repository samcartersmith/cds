{
  "name": "@cbhq/cds-icons",
  "version": "2.0.0",
  "description": "CDS icons",
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "cds",
    "icons"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/cds-icons"
  },
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./fonts/web/icon-font.css": {
      "default": "./fonts/web/icon-font.css"
    },
    "./fonts/web/*.woff2": {
      "default": "./fonts/web/*.woff2"
    },
    "./fonts/native/CoinbaseIcons.ttf": {
      "default": "./fonts/native/CoinbaseIcons.ttf"
    },
    "./*": {
      "types": "./lib/*.d.ts",
      "node": {
        "types": "./lib/*.d.ts",
        "default": "./lib/*.js"
      },
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./lib/index.d.ts",
      "node": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "default": "./lib/index.js"
    }
  },
  "devDependencies": {
    "@cbhq/cds-tasks": "workspace:^",
    "@cbhq/figma-tasks": "workspace:^"
  }
}
