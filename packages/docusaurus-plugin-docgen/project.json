{
  "root": "packages/docusaurus-plugin-docgen",
  "sourceRoot": "packages/docusaurus-plugin-docgen",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@cbhq/cds-tools:build-docusaurus-plugin",
      "outputs": ["{projectRoot}/lib"]
    },
    "debug": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "packages/docusaurus-plugin-docgen",
        "commands": ["node /lib/scripts/debug.js"]
      }
    },
    "watch": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "packages/docusaurus-plugin-docgen",
        "commands": ["yarn docusaurus-plugin watch"]
      }
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    }
  }
}
