{
  "name": "@cbhq/docusaurus-plugin-docgen",
  "version": "0.0.1",
  "description": "Docusaurus plugin for generating api documentation from Typescript files",
  "keywords": [
    "docusaurus",
    "plugin",
    "docgen",
    "docs"
  ],
  "repository": "git@github.cbhq.net:frontend/cds.git",
  "authors": "Coinbase",
  "scripts": {
    "babel": "../../node_modules/.bin/babel",
    "tsc": "../../node_modules/.bin/tsc",
    "build-babel": "yarn babel src --config-file ./babel.config.js --extensions .ts,.tsx --copy-files --no-copy-ignored --delete-dir-on-start --out-dir dist",
    "build-typescript": "yarn tsc -p ./tsconfig.json",
    "build": "yarn build-babel && yarn build-typescript",
    "watch-babel": "yarn build-babel --watch",
    "watch-typescript": "yarn build-typescript --watch",
    "watch": "concurrently 'yarn:watch-*'",
    "format": "nx run docusaurus-plugin-docgen:format",
    "lint": "nx run docusaurus-plugin-docgen:lint",
    "lint.fix": "nx run docusaurus-plugin-docgen:lint --fix",
    "test": "jest",
    "typecheck": "nx run docusaurus-plugin-docgen:typecheck"
  },
  "dependencies": {
    "@cbhq/cds-web": "workspace:*",
    "@docusaurus/logger": "^2.0.0-beta.20",
    "@docusaurus/utils": "2.0.0-beta.18",
    "ejs": "^3.1.7",
    "fast-glob": "^3.2.11",
    "prettier": "^2.5.1",
    "react-docgen-typescript": "^2.0.0",
    "typescript": "~4.5.4"
  },
  "devDependencies": {
    "@cbhq/cds-tools": "workspace:*",
    "@docusaurus/module-type-aliases": "2.0.0-beta.18",
    "@docusaurus/types": "2.0.0-beta.18",
    "@types/ejs": "^3.1.0",
    "@types/lodash": "^4.14.178",
    "concurrently": "^7.1.0",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "main": "./dist/plugin.js",
  "typings": "./dist/plugin.d.ts",
  "exports": {
    ".": "./dist/plugin.js",
    "./components/*": "./dist/components/*.js",
    "./scripts/*": "./dist/scripts/*.js"
  }
}
