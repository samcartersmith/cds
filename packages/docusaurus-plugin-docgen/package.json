{
  "name": "@cbhq/docusaurus-plugin-docgen",
  "version": "0.0.1",
  "description": "Docusaurus plugin for generating api documentation from Typescript files",
  "keywords": [
    "docusaurus",
    "plugin",
    "docgen",
    "docs"
  ],
  "repository": "git@github.cbhq.net:frontend/cds.git",
  "authors": "Coinbase",
  "dependencies": {
    "@docusaurus/logger": "^2.0.0-beta.20",
    "@docusaurus/utils": "2.0.0-beta.18",
    "ejs": "^3.1.7",
    "react-docgen-typescript": "^2.2.2"
  },
  "devDependencies": {
    "@docusaurus/types": "2.0.0-beta.18",
    "@types/ejs": "^3.1.0",
    "@types/lodash": "^4.14.178"
  },
  "peerDependencies": {
    "@cbhq/eslint-plugin": ">=1.5.0",
    "fast-glob": ">=3.2.11",
    "lodash": ">=4.17.21",
    "prettier": ">=2.5.1",
    "type-fest": ">=1.2.0"
  },
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "types": "./dts/index.d.ts",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dts/*.d.ts",
      "node": "./lib/*.js",
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./dts/index.d.ts",
      "node": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "dts/**/*.d.ts",
    "lib/**/*.{js,map}",
    "lib/**/*.ejs.t",
    "src/**/*.{ts,tsx,json}",
    "CHANGELOG.md",
    "README.md"
  ]
}
