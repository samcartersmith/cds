{
  "name": "@cbhq/d3",
  "version": "0.0.2",
  "description": "d3 packages",
  "keywords": [
    "d3"
  ],
  "main": "./index.js",
  "sideEffects": [
    "./transition.js"
  ],
  "files": [
    "**/*.js"
  ],
  "dependencies": {
    "@types/d3-color": "2.0.1",
    "@types/d3-interpolate": "1.4.2",
    "@types/d3-scale": "3.3.0",
    "@types/d3-transition": "1.3.2",
    "d3-array": "2.12.1",
    "d3-dispatch": "1.0.6",
    "d3-ease": "1.0.7",
    "d3-format": "2.0.0",
    "d3-selection": "^1.4.2",
    "d3-time": "2.1.1",
    "d3-time-format": "3.0.0",
    "d3-timer": "1.0.10"
  },
  "dependencyComments": {
    "d3-array": "Dependency of d3-scale",
    "d3-dispatch": "Dependency of d3-transition",
    "d3-ease": "Dependency of d3-transition",
    "d3-format": "Dependency of d3-scale",
    "d3-selection": "Dependency of d3-transition",
    "d3-time": "Dependency of d3-scale",
    "d3-time-format": "Dependency of d3-scale",
    "d3-timer": "Dependency of d3-transition"
  },
  "exports": {
    "./package.json": "./package.json",
    "./interpolate": {
      "types": "./interpolate.d.ts",
      "default": "./interpolate.js"
    },
    "./scale": {
      "types": "./scale.d.ts",
      "default": "./scale.js"
    },
    "./transition": {
      "types": "./transition.d.ts",
      "default": "./transition.js"
    },
    "./color": {
      "types": "./color.d.ts",
      "default": "./color.js"
    },
    ".": "./index.js"
  }
}
