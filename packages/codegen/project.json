{
  "root": "packages/codegen",
  "sourceRoot": "packages/codegen",
  "projectType": "library",
  "implicitDependencies": ["!web", "!common", "!utils", "!web-utils"],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "generate-icon-stories": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "packages/codegen",
        "commands": ["yarn ts-node ./stories/createIconStories.ts"],
        "parallel": false
      }
    },
    "icons": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "packages/codegen",
        "commands": [
          "ts-node ./icons/syncSvgsFromFigma.ts",
          "svgo ../common/internal/data/iconSvgs/*.svg --config=configs/svgo.config.js",
          "ts-node ./icons/build.ts",
          "yarn nx run codegen:generate-icon-stories"
        ],
        "parallel": false
      }
    },
    "illustrations": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "packages/codegen",
        "commands": [
          "ts-node ./illustrations/build.ts",
          "nx run codegen:format",
          "nx run mobile:format",
          "nx run codegen:uploadToStaticAssets"
        ],
        "parallel": false
      }
    },
    "uploadToStaticAssets": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "packages/codegen/illustrations",
        "commands": ["./uploadToStaticAssets.sh"],
        "parallel": false
      }
    },
    "all": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./main.ts"
      }
    },
    "release": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./releasePackages.ts",
        "args": ["--packages=d3|fonts|web|lottie-files|mobile|utils|common"]
      }
    },
    "mobile-routes": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "packages/codegen",
        "commands": [
          "ts-node ./playground/prepareRoutes.ts",
          "ts-node ./playground/prepareNewRoutes.ts"
        ],
        "parallel": true
      }
    },
    "adoption": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./adoption/prepare.ts",
        "NODE_OPTIONS": {
          "trace-deprecation": true,
          "abort-on-uncaught-exception": true,
          "max-old-space-size": 4096
        }
      }
    }
  }
}
