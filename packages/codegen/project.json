{
  "root": "packages/codegen",
  "sourceRoot": "packages/codegen",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "codegen": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./main.ts"
      }
    },
    "release": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./releasePackages.ts",
        "args": ["--packages=fonts|web|lottie-files|mobile|utils|common"]
      }
    },
    "sync_icons": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./icons/syncSvgsFromFigma.ts"
      }
    },
    "build_icons": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./icons/build.ts"
      }
    },
    "build_illustrations": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./illustrations/build.ts"
      }
    },
    "prepare_new_mobile_routes": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./playground/prepareNewRoutes.ts"
      }
    },
    "prepare_mobile_routes": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./playground/prepareRoutes.ts"
      },
      "dependsOn": [{ "target": "prepare_new_mobile_routes", "projects": "self" }]
    },
    "prepare_adoption": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./adoption/prepare.ts",
        "NODE_OPTIONS": {
          "trace-deprecation": true,
          "abort-on-uncaught-exception": true,
          "max-old-space-size": 4096
        }
      }
    },
    "debug_adoption": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./adoption/prepare.ts",
        "NODE_OPTIONS": {
          "trace-deprecation": true,
          "abort-on-uncaught-exception": true,
          "max-old-space-size": 4096
        },
        "debug": true
      }
    }
  }
}
