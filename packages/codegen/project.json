{
  "root": "packages/codegen",
  "sourceRoot": "packages/codegen",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/cds-tools:typecheck"
    },
    "codegen": {
      "executor": "@cbhq/cds-tools:ts-script",
      "options": {
        "scriptPath": "packages/codegen/main.ts"
      }
    },
    "release": {
      "executor": "@cbhq/cds-tools:ts-script",
      "options": {
        "scriptPath": "packages/codegen/releasePackages.ts",
        "args": ["--packages=fonts|web|lottie-files|mobile|utils|common"]
      }
    },
    "release.beta": {
      "executor": "@cbhq/cds-tools:ts-script",
      "options": {
        "scriptPath": "packages/codegen/releasePackages.ts",
        "args": ["--packages=fonts|web|lottie-files|mobile|utils|common", "--beta"]
      }
    },
    "sync_icons": {
      "executor": "@cbhq/cds-tools:ts-script",
      "options": {
        "scriptPath": "packages/codegen/icons/syncSvgsFromFigma.ts"
      }
    },
    "build_icons": {
      "executor": "@cbhq/cds-tools:ts-script",
      "options": {
        "scriptPath": "packages/codegen/icons/build.ts"
      }
    },
    "build_illustrations": {
      "executor": "@cbhq/cds-tools:ts-script",
      "options": {
        "scriptPath": "packages/codegen/illustrations/build.ts"
      }
    },
    "prepare_new_mobile_routes": {
      "executor": "@cbhq/cds-tools:ts-script",
      "options": {
        "scriptPath": "packages/codegen/playground/prepareNewRoutes.ts"
      }
    },
    "prepare_mobile_routes": {
      "executor": "@cbhq/cds-tools:ts-script",
      "options": {
        "scriptPath": "packages/codegen/playground/prepareRoutes.ts"
      },
      "dependsOn": [{ "target": "prepare_new_mobile_routes", "projects": "self" }]
    },
    "prepare_adoption": {
      "executor": "@cbhq/cds-tools:ts-script",
      "options": {
        "scriptPath": "packages/codegen/adoption/prepare.ts",
        "args": ["--tempDir=packages/codegen/adoption/temp"],
        "envs": {
          "NODE_OPTIONS": "--trace-deprecation --abort-on-uncaught-exception --max-old-space-size=4096"
        }
      }
    },
    "debug_adoption": {
      "executor": "@cbhq/cds-tools:ts-script",
      "options": {
        "scriptPath": "packages/codegen/adoption/prepare.ts",
        "args": ["--tempDir=packages/codegen/adoption/temp", "debug=1"],
        "envs": {
          "NODE_OPTIONS": "--trace-deprecation --abort-on-uncaught-exception --max-old-space-size=4096"
        }
      }
    }
  }
}
