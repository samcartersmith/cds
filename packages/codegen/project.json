{
  "name": "codegen",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/codegen",
  "projectType": "library",
  "implicitDependencies": [
    "!web",
    "!common",
    "!utils"
  ],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "generate-icon-stories": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/codegen",
        "commands": [
          "yarn ts-node ./createIconStories/main.ts"
        ],
        "parallel": false
      }
    },
    "icons": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/codegen",
        "commands": [
          "ts-node ./icons/syncSvgsFromFigma.ts",
          "svgo ../common/internal/data/iconSvgs/*.svg --config=configs/svgo.config.js",
          "ts-node ./icons/build.ts",
          "nx run codegen:generate-icon-stories"
        ],
        "parallel": false
      }
    },
    "illustrations": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/codegen",
        "commands": [
          "ts-node ./illustrations/build.ts",
          "nx run codegen:format",
          "nx run mobile:format",
          "nx run codegen:uploadToStaticAssets"
        ],
        "parallel": false
      }
    },
    "uploadToStaticAssets": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/codegen/illustrations",
        "commands": [
          "./uploadToStaticAssets.sh"
        ],
        "parallel": false
      }
    },
    "all": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./main.ts"
      }
    },
    "updateWebsiteChangelogs": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./website/updateWebsiteChangelogs.ts"
      }
    },
    "updatePkgsForGenericBump": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./release/updatePkgsForGenericBump.ts"
      }
    },
    "updateWebsiteChangelogs": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./website/updateWebsiteChangelogs.ts",
        "args": [
          "--packages=common|icons|illustrations|lottie-files|mobile|ui-mobile-playground|web|utils|fonts"
        ]
      }
    },
    "mobile-routes": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/codegen",
        "commands": [
          "ts-node ./playground/prepareRoutes.ts"
        ],
        "parallel": true
      }
    }
  }
}
