{
  "name": "codegen",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/codegen",
  "projectType": "library",
  "implicitDependencies": [
    "!web",
    "!common",
    "!utils",
    "!web-utils"
  ],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "all": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./main.ts"
      }
    },
    "release": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./releasePackages.ts",
        "args": [
          "--packages=d3|fonts|web|lottie-files|mobile|utils|common"
        ]
      }
    },
    "mobile-routes": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/codegen",
        "commands": [
          "ts-node ./playground/prepareRoutes.ts",
          "ts-node ./playground/prepareNewRoutes.ts"
        ],
        "parallel": true
      }
    }
  }
}
