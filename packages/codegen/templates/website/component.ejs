---
title: <%- data.displayName %>
slug: <%- data.slug %>
hide_title: true
---

import { VStack } from "@cbhq/cds-web/alpha/VStack";
import { Link } from "@cbhq/cds-web/typography/Link";
import { TextDisplay3 } from "@cbhq/cds-web/typography/TextDisplay3";
import Tabs from '@theme/Tabs';
import TabItem from '@theme/TabItem';

<% if (data.hasA11y){ _%>
import A11y from "./_a11y.mdx";
<% } _%>
<% if (data.hasIntro){ _%>
import Intro from "./_intro.mdx";
<% } _%>
<% if (data.hasDesign){ _%>
import Design from "./_design.mdx";
<% } _%>
<% if (data.hasUsage){ _%>
import Usage from "./_usage.mdx";
<% } _%>
import Props from "./_implementation.mdx";


<VStack gap={3}>
  <TextDisplay3 as="h1"><%- data.displayName %></TextDisplay3>
  <Link to="<%- data.sourceUrl %>" openInNewWindow><%- data.importPath %></Link>
  <Tabs>
    <% if (data.hasDesign){ _%>
    <TabItem value="guidelines" label="Guidelines">
      <VStack gap={3}>
        <Design />
      </VStack>
    </TabItem>
    <% } _%>
    <TabItem value="implementation" label="Implementation" default>
      <VStack gap={3}>
        <% if (data.hasIntro){ _%>
        <Intro />
        <% } _%>
        <% if (data.hasUsage){ _%>
        <Usage />
        <% } _%>
        <% if (data.hasA11y){ _%>
        <A11y />
        <% } _%>
        <Props />
      </VStack>
    </TabItem>
  </Tabs>
</VStack>