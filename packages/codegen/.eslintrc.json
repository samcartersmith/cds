{
  "extends": ["../../.eslintrc.js", "plugin:@cbhq/node"],
  "overrides": [
    {
      "files": ["**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            // Lodash doesn't need to be tree shakeable in codegen
            "paths": ["!lodash"]
          }
        ],
        "no-restricted-globals": "off"
      }
    }
  ]
}
