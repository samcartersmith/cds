{
  "name": "@cds/codegen",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "adoption": "nx run codegen:prepare_adoption",
    "all": "nx run codegen:codegen",
    "codegen": "nx run codegen:codegen",
    "cli": "ts-node ./bin.ts",
    "docs.internal": "yarn cli website/docs-internal",
    "format": "nx run codegen:format",
    "icons": "nx run codegen:sync_icons && svgo ../common/internal/data/iconSvgs/*.svg --config=configs/svgo.config.js && nx run codegen:build_icons",
    "illustrations": "nx run codegen:build_illustrations",
    "lint": "nx codegen:lint",
    "lint.fix": "nx codegen:lint --fix",
    "routes": "nx run codegen:prepare_mobile_routes",
    "release": "nx run codegen:release",
    "release.beta": "nx run codegen:release.beta",
    "test": "jest",
    "typecheck": "nx run codegen:typecheck"
  },
  "dependencies": {
    "@k-vyn/coloralgorithm": "^1.0.0",
    "@types/svgo": "^2.3.0",
    "axios": "^0.18.0",
    "ejs": "^3.1.7",
    "enquirer": "^2.3.6",
    "hygen": "patch:hygen@^6.2.0#./patches/hygen.patch",
    "react-docgen-typescript": "^2.0.0",
    "svgo": "^2.3.0",
    "ts-node": "^10.7.0",
    "yargs": "^17.3.1",
    "yargs-parser": "^21.0.1"
  }
}
