{
  "name": "@cbhq/figma-api",
  "version": "0.0.1",
  "description": "Client for interacting with the Figma API",
  "keywords": [
    "figma",
    "cds"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/figma-api"
  },
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "types": "./dts/index.d.ts",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dts/*.d.ts",
      "node": "./lib/*.js",
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./dts/index.d.ts",
      "node": "./lib/index.js",
      "default": "./lib/index.js"
    }
  }
}
