{
  "name": "illustrations",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/illustrations/src",
  "projectType": "library",
  "targets": {
    "export-package-version": {
      "executor": "@cbhq/cds-tasks:export-package-version"
    },
    "build": {
      "outputs": [
        "{projectRoot}/assets",
        "{projectRoot}/lib"
      ],
      "executor": "@cbhq/mono-tasks:build-package"
    },
    "mobile-build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "build"
      ],
      "options": {
        "command": "echo 'Building illustrations for mobile'"
      }
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "sync": {
      "executor": "@cbhq/figma-tasks:sync-illustrations",
      "dependsOn": [
        "^build"
      ],
      "options": {
        "figmaApiFileId": "LmkJatvMRVzNgfiIkJDb99",
        "changelogFile": "./CHANGELOG.md",
        "manifestFile": "./src/__generated__/manifest.json",
        "darkModeManifestFile": "libs/figma-styles/__generated__/illustration/dark/manifest.json",
        "lightModeManifestFile": "libs/figma-styles/__generated__/illustration/light/manifest.json",
        "generatedDirectory": "./src/__generated__"
      }
    },
    "sync-styles": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "^build"
      ],
      "options": {
        "command": "nx run figma-styles:sync"
      }
    },
    "generate-stories": {
      "executor": "@cbhq/mono-tasks:run-script",
      "dependsOn": [
        "^build"
      ],
      "options": {
        "script": "./scripts/generateStories.ts"
      }
    },
    "uploadToStaticAssets": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/illustrations",
        "commands": [
          "./scripts/uploadToStaticAssets.sh"
        ]
      }
    },
    "release": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "^build"
      ],
      "options": {
        "commands": [
          "nx run illustrations:sync",
          "nx run illustrations:generate-stories"
        ],
        "parallel": false
      }
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "watch": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "packages/illustrations",
        "commands": [
          "nx run figma-tasks:watch",
          "packemon watch --quiet --loadConfigs"
        ]
      }
    }
  }
}
