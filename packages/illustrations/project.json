{
  "name": "illustrations",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/illustrations",
  "projectType": "library",
  "targets": {
    "prebuild": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "echo 'Building dts for .nx directory for non pakemon packages which require generated types for project references'",
          "tsc --project packages/illustrations/tsconfig.json"
        ],
        "parallel": false
      }
    },
    "build": {
      "outputs": ["{projectRoot}/dts", "{projectRoot}/lib"],
      "dependsOn": ["^build", "prebuild"],
      "executor": "@cbhq/mono-tasks:build-package"
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "sync": {
      "executor": "@cbhq/figma-tasks:sync-illustrations",
      "dependsOn": ["^build"],
      "options": {
        "figmaApiFileId": "LmkJatvMRVzNgfiIkJDb99",
        "changelogFile": "./CHANGELOG.md",
        "manifestFile": "./src/__generated__/manifest.json",
        "darkModeManifestFile": "packages/figma-styles/__generated__/illustration/dark/manifest.json",
        "lightModeManifestFile": "packages/figma-styles/__generated__/illustration/light/manifest.json",
        "generatedDirectory": "./src/__generated__"
      }
    },
    "sync-styles": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "command": "nx run figma-styles:sync"
      }
    },
    "uploadToStaticAssets": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/illustrations",
        "commands": ["./uploadToStaticAssets.sh"]
      }
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "watch": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "packages/illustrations",
        "commands": ["nx run figma-tasks:watch", "packemon watch --quiet --loadConfigs"]
      }
    }
  }
}
