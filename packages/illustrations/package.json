{
  "name": "@cbhq/cds-illustrations",
  "version": "1.8.4",
  "description": "CDS illustrations",
  "keywords": [
    "cds",
    "illustrations"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/cds-illustrations"
  },
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "devDependencies": {
    "@cbhq/figma-styles": "workspace:^",
    "@cbhq/figma-tasks": "workspace:^"
  },
  "types": "./lib/index.d.ts",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./lib/*.d.ts",
      "node": {
        "types": "./lib/*.d.ts",
        "default": "./lib/*.js"
      },
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./lib/index.d.ts",
      "node": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "default": "./lib/index.js"
    }
  }
}
