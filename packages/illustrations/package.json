{
  "name": "@cbhq/cds-illustrations",
  "version": "1.5.0",
  "description": "CDS illustrations",
  "keywords": [
    "cds",
    "illustrations"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/cds-illustrations"
  },
  "packemon": {
    "format": "lib",
    "platform": "node"
  },
  "devDependencies": {
    "@cbhq/figma-styles": "workspace:^",
    "@cbhq/figma-tasks": "workspace:^"
  },
  "types": "./dts/index.d.ts",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "types": "./dts/*.d.ts",
      "node": "./lib/*.js",
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./dts/index.d.ts",
      "node": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "dts/**/*.d.ts",
    "lib/**/*.{js,map}",
    "src/**/*.{ts,tsx,json}",
    "CHANGELOG.md",
    "README.md"
  ]
}
