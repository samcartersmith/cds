{
  "name": "@cbhq/cds-mobile-internal",
  "version": "8.0.0",
  "private": true,
  "description": "Coinbase Design System - Mobile Internal",
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/mobile-internal"
  },
  "type": "module",
  "main": "./esm/index.js",
  "types": "./dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dts/index.d.ts",
      "default": "./esm/index.js"
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "default": "./esm/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dts",
    "esm",
    "CHANGELOG"
  ],
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "@cbhq/cds-common": "8.1.0",
    "@cbhq/cds-icons": "^5.0.0",
    "@cbhq/cds-illustrations": "^4.12.0",
    "@cbhq/cds-lottie-files": "^3.0.0",
    "@cbhq/cds-mobile": "8.1.0",
    "@cbhq/cds-utils": "^2.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@types/react": "^18.3.12"
  }
}
