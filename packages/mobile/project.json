{
  "root": "packages/mobile",
  "sourceRoot": "packages/mobile",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/cds-tools:typecheck"
    },
    "build": {
      "executor": "@cbhq/cds-tools:build-package",
      "options": {
        "destinationDir": ".nx/dist/packages/mobile",
        "staticFilesToIgnore": [
          "babel.build.config.js",
          "babel.config.js",
          "jest.config.js",
          "tsconfig.json",
          "tsconfig.build.json",
          "project.json"
        ],
        "babelConfig": "./packages/mobile/babel.build.config.js",
        "babelExtensions": [".ts", ".tsx"],
        "babelIgnore": ["**/*.js", "**/*.test.ts", "**/*.test.tsx"],
        "typescriptConfig": "packages/mobile/tsconfig.build.json"
      }
    }
  }
}
