{
  "extends": "../../tsconfig.projectOptions.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "../../.nx/dts/packages/docusaurus-theme"
  },
  "include": [
    "src",
    "src/**/*.ts",
    "scripts"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/**/*",
    "lib"
  ],
  "references": [
    {
      "path": "../docusaurus-plugin-docgen"
    },
    {
      "path": "../docusaurus-plugin-kbar"
    },
    {
      "path": "../common"
    },
    {
      "path": "../web"
    },
    {
      "path": "../web-utils"
    }
  ],
  "ts-node": {
    "transpileOnly": true,
    "files": true,
    "require": [
      "tsconfig-paths/register"
    ]
  }
}
