{
  "root": "packages/docusaurus-theme",
  "sourceRoot": "packages/docusaurus-theme",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@cbhq/cds-tools:build-docusaurus-plugin",
      "options": {
        "postbuild": "./scripts/postbuild.ts"
      },
      "outputs": ["{projectRoot}/lib"]
    },
    "watch": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "cwd": "packages/docusaurus-theme",
        "commands": [
          "yarn docusaurus-plugin watch",
          "nodemon --watch 'src/**/*.ts' --watch 'src/**/*.tsx' --exec ts-node ./scripts/postbuild.ts"
        ],
        "parallel": true
      }
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    }
  }
}
