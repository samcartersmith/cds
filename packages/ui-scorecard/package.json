{
  "name": "@cbhq/ui-scorecard",
  "version": "0.0.4",
  "description": "UI scorecard and adoption tracking cli tool",
  "keywords": [
    "ui",
    "scorecard"
  ],
  "main": "./cjs/index.cjs",
  "bin": "./cjs/bin.cjs",
  "packemon": {
    "format": "cjs",
    "platform": "node"
  },
  "scripts": {
    "watch": "packemon watch --quiet --loadConfigs"
  },
  "type": "commonjs",
  "executors": "./executors.json",
  "dependencies": {
    "aws-sdk": "^2.1207.0",
    "chalk": "^4.1.2",
    "execa": "^5.1.1",
    "jest-serializer-ansi-escapes": "^2.0.1",
    "pretty-format": "^29.3.1",
    "update-notifier": "^5.1.0",
    "yargs": "^17.5.1"
  },
  "devDependencies": {
    "@types/update-notifier": "^5.1.0",
    "@types/yargs": "^17.0.11",
    "packemon": "^2.4.0"
  },
  "peerDependencies": {
    "@cbhq/mono-tasks": "^0.6.8",
    "typescript": "~4.9.4"
  },
  "exports": {
    "./package.json": "./package.json",
    "./bin": {
      "types": "./dts/bin.d.ts",
      "node": "./lib/bin.js",
      "default": "./lib/bin.js"
    },
    ".": {
      "types": "./dts/index.d.ts",
      "node": {
        "import": "./cjs/index-wrapper.mjs",
        "require": "./cjs/index.cjs"
      }
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "node": {
        "require": "./cjs/*.cjs"
      }
    }
  },
  "types": "./dts/index.d.ts"
}
