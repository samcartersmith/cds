{
  "name": "@cbhq/ui-scorecard",
  "version": "0.2.7",
  "description": "UI scorecard and adoption tracking cli tool",
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "packages/ui-scorecard"
  },
  "executors": "./executors.json",
  "bin": "./cjs/bin.js",
  "type": "commonjs",
  "main": "./cjs/index.js",
  "types": "./dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dts/index.d.ts",
      "default": "./cjs/index.js"
    },
    "./adoption": {
      "types": "./dts/adoption/index.d.ts",
      "default": "./cjs/adoption/index.js"
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "default": "./cjs/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "cjs",
    "dts",
    "CHANGELOG",
    "executors.json"
  ],
  "peerDependencies": {
    "@cbhq/mono-tasks": "^1.16.0",
    "typescript": "~5.7.2"
  },
  "dependencies": {
    "@cbhq/client-analytics": "^10.9.1",
    "aws-sdk": "^2.1207.0",
    "chalk": "^4.1.2",
    "execa": "^5.1.1",
    "jest-serializer-ansi-escapes": "^2.0.1",
    "pretty-format": "^29.3.1",
    "update-notifier": "^5.1.0",
    "yargs": "^17.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@cbhq/mono-tasks": "^1.16.0",
    "@types/update-notifier": "^5.1.0",
    "@types/yargs": "^17.0.11",
    "typescript": "~5.7.2"
  }
}
