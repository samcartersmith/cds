{
  "name": "@cbhq/ui-scorecard",
  "version": "0.1.9",
  "description": "UI scorecard and adoption tracking cli tool",
  "keywords": [
    "ui",
    "scorecard"
  ],
  "main": "./cjs/index.cjs",
  "bin": "./cjs/bin.cjs",
  "packemon": {
    "format": "cjs",
    "platform": "node",
    "inputs": {
      "bin": "src/bin.ts",
      "index": "src/index.ts"
    }
  },
  "scripts": {
    "watch": "packemon watch --quiet --loadConfigs"
  },
  "type": "commonjs",
  "executors": "./executors.json",
  "dependencies": {
    "@cbhq/client-analytics": "^10.9.1",
    "aws-sdk": "^2.1207.0",
    "chalk": "^4.1.2",
    "execa": "^5.1.1",
    "jest-serializer-ansi-escapes": "^2.0.1",
    "pretty-format": "^29.3.1",
    "update-notifier": "^5.1.0",
    "yargs": "^17.5.1"
  },
  "devDependencies": {
    "@types/update-notifier": "^5.1.0",
    "@types/yargs": "^17.0.11",
    "packemon": "^3.1.1"
  },
  "peerDependencies": {
    "@cbhq/mono-tasks": "^0.10.1",
    "typescript": "~5.2.2"
  },
  "types": "./cjs/index.d.ts",
  "engines": {
    "node": ">=18.14.2"
  },
  "exports": {
    "./package.json": "./package.json",
    "./*": {
      "node": {
        "types": "./cjs/*.d.ts",
        "require": "./cjs/*.cjs"
      }
    },
    ".": {
      "node": {
        "types": "./cjs/index.d.ts",
        "import": "./cjs/index-wrapper.mjs",
        "require": "./cjs/index.cjs"
      }
    }
  }
}
