{
  "name": "profile-package",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/profile-package/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "command": "rm -rf esm && rollup -c",
      "options": {
        "cwd": "packages/profile-package"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "dev",
      "configurations": {
        "dev": {
          "command": "tsc --build --pretty --verbose"
        },
        "prod": {
          "command": "tsc --build ./tsconfig.build.json --pretty --verbose"
        }
      }
    }
  }
}
