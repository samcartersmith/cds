{
  "name": "@cbhq/profile-package",
  "version": "0.0.2",
  "description": "Utilities and CLI for profiling JavaScript package exports",
  "type": "module",
  "main": "./esm/index.js",
  "types": "./dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dts/index.d.ts",
      "default": "./esm/index.js"
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "default": "./esm/*.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dts",
    "esm",
    "CHANGELOG"
  ],
  "scripts": {
    "build": "rm -rf esm dts && tsc && rollup -c"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "depcheck": "^1.4.7",
    "diff": "^5.1.0",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-typescript": "^7.18.6",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.22.4",
    "tslib": "^2",
    "typescript": "~5.6.2"
  }
}
