{
  "extends": "../../tsconfig.projectOptions.json",
  "compilerOptions": {
    "rootDir": "./",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationDir": "dts",
    "esModuleInterop": true
  },
  "include": ["src", "package.json"],
  "exclude": ["node_modules"]
}
