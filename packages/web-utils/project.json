{
  "root": "packages/web-utils",
  "sourceRoot": "packages/web-utils",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "typecheck": {
      "executor": "./tools/executors/typecheck:typecheck"
    },
    "build": {
      "executor": "./tools/executors/build-package:build-package",
      "options": {
        "destinationDir": "packages/web-utils/dist",
        "staticFilesToIgnore": ["tsconfig.json", "tsconfig.build.json", "project.json"],
        "babelConfig": "./babel.build.config.js",
        "babelExtensions": [".ts", ".tsx"],
        "babelIgnore": ["**/*.js", "**/*.test.ts", "**/*.test.tsx"],
        "typescriptConfig": "packages/web-utils/tsconfig.build.json"
      }
    }
  }
}
