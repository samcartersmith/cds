{
  "name": "@cbhq/cds-web-utils",
  "version": "0.0.0",
  "private": true,
  "description": "Jest utils and developer tools.",
  "dependencies": {
    "@babel/types": "^7.20.7",
    "@testing-library/react": "^13.4.0",
    "chalk": "^4.1.2",
    "jest-axe": "^4.1.0",
    "linaria": "^2.3.1",
    "source-map": "^0.7.3",
    "stylis": "^3.5.4",
    "yargs": "^17.5.1"
  },
  "keywords": [
    "web utils"
  ],
  "packemon": [
    {
      "format": "lib",
      "platform": "node",
      "inputs": {
        "index": "src/index.ts",
        "jest": "src/jest/index.ts"
      },
      "externals": [
        "axe-core"
      ]
    }
  ],
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./jest": {
      "types": "./lib/jest/index.d.ts",
      "node": {
        "types": "./lib/jest/index.d.ts",
        "default": "./lib/jest/index.js"
      },
      "default": "./lib/jest/index.js"
    },
    ".": {
      "types": "./lib/index.d.ts",
      "node": {
        "types": "./lib/index.d.ts",
        "default": "./lib/index.js"
      },
      "default": "./lib/index.js"
    },
    "./*": {
      "types": "./lib/*.d.ts",
      "node": {
        "types": "./lib/*.d.ts",
        "default": "./lib/*.js"
      },
      "default": "./lib/*.js"
    }
  }
}
