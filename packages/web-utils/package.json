{
  "name": "@cbhq/cds-web-utils",
  "version": "0.0.0",
  "private": true,
  "description": "Jest utils and developer tools.",
  "dependencies": {
    "@babel/types": "^7.20.7",
    "@testing-library/react": "^12.1.5",
    "chalk": "^4.1.2",
    "jest-axe": "^4.1.0",
    "linaria": "^2.3.1",
    "source-map": "^0.7.3",
    "stylis": "^3.5.4",
    "yargs": "^15.3.1"
  },
  "keywords": [
    "web utils"
  ],
  "packemon": {
    "format": "lib",
    "platform": "node",
    "externals": [
      "axe-core"
    ]
  },
  "types": "./dts/index.d.ts",
  "main": "./lib/index.js",
  "exports": {
    "./package.json": "./package.json",
    "./jest": {
      "types": "./dts/jest/index.d.ts",
      "node": "./lib/jest/index.js",
      "default": "./lib/jest/index.js"
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "node": "./lib/*.js",
      "default": "./lib/*.js"
    },
    ".": {
      "types": "./dts/index.d.ts",
      "node": "./lib/index.js",
      "default": "./lib/index.js"
    }
  }
}
