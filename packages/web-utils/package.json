{
  "name": "@cbhq/cds-web-utils",
  "version": "0.0.0",
  "description": "Jest utils and developer tools.",
  "dependencies": {
    "@babel/types": "^7.20.7",
    "@cbhq/cds-tools": "workspace:*",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.4.3",
    "chalk": "^4.1.0",
    "css-loader": "^6.2.0",
    "dotenv": "^8.2.0",
    "dotenv-webpack": "^7.0.3",
    "file-loader": "^6.2.0",
    "html-loader": "^2.1.2",
    "html-webpack-plugin": "^5.3.2",
    "linaria": "^2.3.1",
    "mini-css-extract-plugin": "^2.2.0",
    "node-polyfill-webpack-plugin": "^1.1.4",
    "source-map": "^0.7.3",
    "style-loader": "^3.2.1",
    "stylis": "^3.5.4",
    "url-loader": "^4.1.1",
    "webpack": "^5.63.0",
    "webpack-bundle-analyzer": "^4.4.2",
    "webpack-cli": "^4.7.2",
    "webpack-dev-server": "^3.11.0",
    "yargs": "^15.3.1"
  },
  "keywords": [
    "web utils"
  ],
  "scripts": {
    "babel": "../../node_modules/.bin/babel",
    "build": "yarn babel . --extensions .ts,.tsx --delete-dir-on-start --out-dir dist",
    "watch": "yarn build --watch"
  },
  "exports": {
    ".": {
      "node": "./dist/index.js",
      "require": "./dist/index.js",
      "import": "./index.ts",
      "types": "./index.ts"
    },
    "./babel/*": {
      "node": "./dist/babel/*.js",
      "require": "./dist/babel/*.js",
      "import": "./babel/*.ts",
      "types": "./babel/*.ts"
    },
    "./jest": {
      "node": "./dist/jest/index.js",
      "require": "./dist/jest/index.js",
      "import": "./jest/index.ts",
      "types": "./jest/index.ts"
    },
    "./monorepo": {
      "node": "./dist/monorepo/index.js",
      "require": "./dist/monorepo/index.js",
      "import": "./monorepo/index.ts",
      "types": "./monorepo/index.ts"
    }
  }
}
