{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "lib": [
      "dom",
      "esnext"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noErrorTruncation": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "paths": {
      "@cbhq/cds-common-internal": [
        "packages/common-internal/src"
      ],
      "@cbhq/cds-common-internal/*": [
        "packages/common-internal/src/*"
      ],
      "@cbhq/cds-fonts": [
        "packages/fonts/src"
      ],
      "@cbhq/cds-fonts/*": [
        "packages/fonts/src/*"
      ],
      "@cbhq/cds-mobile-internal": [
        "packages/mobile-internal/src"
      ],
      "@cbhq/cds-mobile-internal/*": [
        "packages/mobile-internal/src/*"
      ],
      "@cbhq/cds-usage-mcp": [
        "libs/cds-usage-mcp/src"
      ],
      "@cbhq/cds-usage-mcp/*": [
        "libs/cds-usage-mcp/src/*"
      ],
      "@cbhq/cds-web-internal": [
        "packages/web-internal/src"
      ],
      "@cbhq/cds-web-internal/*": [
        "packages/web-internal/src/*"
      ],
      "@cbhq/cds-web-utils": [
        "libs/web-utils/src"
      ],
      "@cbhq/cds-web-utils/*": [
        "libs/web-utils/src/*"
      ],
      "@cbhq/figma-analytics-export": [
        "libs/figma-analytics-export/src"
      ],
      "@cbhq/figma-analytics-export/*": [
        "libs/figma-analytics-export/src/*"
      ],
      "@cbhq/figma-api": [
        "libs/figma-api/src"
      ],
      "@cbhq/figma-api/*": [
        "libs/figma-api/src/*"
      ],
      "@cbhq/script-utils": [
        "libs/script-utils/src"
      ],
      "@cbhq/script-utils/*": [
        "libs/script-utils/src/*"
      ],
      "@cbhq/ui-scorecard": [
        "packages/ui-scorecard/src"
      ],
      "@cbhq/ui-scorecard/*": [
        "packages/ui-scorecard/src/*"
      ]
    }
  }
}
