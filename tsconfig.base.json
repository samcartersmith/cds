{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "lib": [
      "dom",
      "esnext"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noErrorTruncation": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2020",
    "paths": {
      ":cds-website/*": [
        "apps/website/*"
      ],
      ":next-app/*": [
        "apps/next-app/src/*"
      ],
      "@cbhq/cds-common": [
        "packages/common/src"
      ],
      "@cbhq/cds-common/*": [
        "packages/common/src/*"
      ],
      "@cbhq/cds-common2": [
        "packages/cds-common2/src"
      ],
      "@cbhq/cds-common2/*": [
        "packages/cds-common2/src/*"
      ],
      "@cbhq/cds-fonts": [
        "packages/fonts/src"
      ],
      "@cbhq/cds-fonts/*": [
        "packages/fonts/src/*"
      ],
      "@cbhq/cds-icons": [
        "packages/icons/src"
      ],
      "@cbhq/cds-icons/*": [
        "packages/icons/src/*"
      ],
      "@cbhq/cds-illustrations": [
        "packages/illustrations/src"
      ],
      "@cbhq/cds-illustrations/*": [
        "packages/illustrations/src/*"
      ],
      "@cbhq/cds-lottie-files": [
        "packages/lottie-files/src"
      ],
      "@cbhq/cds-lottie-files/*": [
        "packages/lottie-files/src/*"
      ],
      "@cbhq/cds-lottie-files2": [
        "packages/lottie-files2/src"
      ],
      "@cbhq/cds-lottie-files2/*": [
        "packages/lottie-files2/src/*"
      ],
      "@cbhq/cds-mobile": [
        "packages/mobile/src"
      ],
      "@cbhq/cds-mobile-visualization": [
        "packages/mobile-visualization/src"
      ],
      "@cbhq/cds-mobile-visualization/*": [
        "packages/mobile-visualization/src/*"
      ],
      "@cbhq/cds-mobile-visualization2": [
        "packages/mobile-visualization2/src"
      ],
      "@cbhq/cds-mobile-visualization2/*": [
        "packages/mobile-visualization2/src/*"
      ],
      "@cbhq/cds-mobile/*": [
        "packages/mobile/src/*"
      ],
      "@cbhq/cds-mobile2": [
        "packages/cds-mobile2/src"
      ],
      "@cbhq/cds-mobile2/*": [
        "packages/cds-mobile2/src/*"
      ],
      "@cbhq/cds-utils": [
        "packages/utils/src"
      ],
      "@cbhq/cds-utils/*": [
        "packages/utils/src/*"
      ],
      "@cbhq/cds-web": [
        "packages/web/src"
      ],
      "@cbhq/cds-web-utils": [
        "libs/web-utils/src"
      ],
      "@cbhq/cds-web-utils/*": [
        "libs/web-utils/src/*"
      ],
      "@cbhq/cds-web-visualization": [
        "packages/web-visualization/src"
      ],
      "@cbhq/cds-web-visualization/*": [
        "packages/web-visualization/src/*"
      ],
      "@cbhq/cds-web-visualization2": [
        "packages/web-visualization2/src"
      ],
      "@cbhq/cds-web-visualization2/*": [
        "packages/web-visualization2/src/*"
      ],
      "@cbhq/cds-web/*": [
        "packages/web/src/*"
      ],
      "@cbhq/cds-web2": [
        "packages/cds-web2/src"
      ],
      "@cbhq/cds-web2/*": [
        "packages/cds-web2/src/*"
      ],
      "@cbhq/docusaurus-plugin-docgen": [
        "libs/docusaurus-plugin-docgen/src"
      ],
      "@cbhq/docusaurus-plugin-docgen/*": [
        "libs/docusaurus-plugin-docgen/src/*"
      ],
      "@cbhq/docusaurus-plugin-kbar": [
        "libs/docusaurus-plugin-kbar/src"
      ],
      "@cbhq/docusaurus-plugin-kbar/*": [
        "libs/docusaurus-plugin-kbar/src/*"
      ],
      "@cbhq/docusaurus-preset": [
        "libs/docusaurus-preset/src"
      ],
      "@cbhq/docusaurus-preset/*": [
        "libs/docusaurus-preset/src/*"
      ],
      "@cbhq/docusaurus-theme": [
        "libs/docusaurus-theme/src"
      ],
      "@cbhq/docusaurus-theme/*": [
        "libs/docusaurus-theme/src/*"
      ],
      "@cbhq/figma-api": [
        "libs/figma-api/src"
      ],
      "@cbhq/figma-api/*": [
        "libs/figma-api/src/*"
      ],
      "@cbhq/figma-styles": [
        "libs/figma-styles/src"
      ],
      "@cbhq/figma-styles/*": [
        "libs/figma-styles/src/*"
      ],
      "@cbhq/script-utils": [
        "libs/script-utils/src"
      ],
      "@cbhq/script-utils/*": [
        "libs/script-utils/src/*"
      ],
      "@cbhq/ui-mobile-playground": [
        "packages/ui-mobile-playground/src"
      ],
      "@cbhq/ui-mobile-playground/*": [
        "packages/ui-mobile-playground/src/*"
      ],
      "@cbhq/ui-mobile-playground2": [
        "packages/ui-mobile-playground2/src"
      ],
      "@cbhq/ui-mobile-playground2/*": [
        "packages/ui-mobile-playground2/src/*"
      ],
      "@cbhq/ui-mobile-visreg": [
        "packages/ui-mobile-visreg/src"
      ],
      "@cbhq/ui-mobile-visreg/*": [
        "packages/ui-mobile-visreg/src/*"
      ],
      "@cbhq/ui-scorecard": [
        "packages/ui-scorecard/src"
      ],
      "@cbhq/ui-scorecard/*": [
        "packages/ui-scorecard/src/*"
      ],
      "@site/*": [
        "apps/docs/*"
      ]
    }
  }
}
