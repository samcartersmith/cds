{
  "name": "design-system",
  "version": "1.0.0",
  "private": true,
  "description": "Coinbase design system",
  "repository": "git@github.cbhq.net:frontend/cds.git",
  "scripts": {
    "____apps____": "✨✨✨ run 'yarn {app} {script}', i.e. yarn website start. scripts are in apps/{app}/package.json ✨✨✨",
    "codegen": "yarn workspace @cds/codegen",
    "playground": "yarn workspace @cds/mobile-playground",
    "storybook": "yarn workspace @cds/storybook",
    "website": "yarn workspace @cds/website",
    "___packages___": "✨✨✨ run 'yarn {package} {script}'. i.e. yarn common build. scripts are in packages/{package}/package.json ✨✨✨",
    "common": "yarn workspace @cbhq/cds-common",
    "fonts": "yarn workspace @cbhq/cds-fonts",
    "lottie": "yarn workspace @cbhq/cds-lottie-files",
    "mobile": "yarn workspace @cbhq/cds-mobile",
    "utils": "yarn workspace @cbhq/cds-utils",
    "web": "yarn workspace @cbhq/cds-web",
    "___global___": "✨✨✨ run scripts for any affected nx projects in repo ✨✨✨",
    "affected": "yarn nx affected --base=master --head=HEAD",
    "affected:dep-graph": "yarn nx affected:dep-graph",
    "build": "yarn affected --target=build",
    "format": "yarn affected --target=format",
    "lint": "yarn affected --target=lint",
    "lint.fix": "yarn affected --target=lint --fix",
    "test": "yarn affected --target=test",
    "typecheck": "yarn affected --target=typecheck",
    "stylelint": "yarn affected --target=lint-styles",
    "stylelint.fix": "yarn affected --target=lint-styles --fix",
    "____misc____": "✨✨✨ misc scripts ✨✨✨",
    "codeowners": "mono-pipeline sync-codeowners",
    "dep-graph": "yarn nx dep-graph",
    "diagnose": "mono-env diagnose --group common web",
    "help": "yarn nx help",
    "postinstall": "./setup.sh",
    "release": "yarn codegen release && yarn codegen docs.internal && yarn codegen docs",
    "setup-env": "mono-env setup --group common web",
    "validate": "yarn nx workspace-lint"
  },
  "resolutions": {
    "colors": "1.4.0",
    "coa": "2.0.2",
    "@docusaurus/core@2.0.0-beta.6": "patch:@docusaurus/core@npm:2.0.0-beta.6#.yarn/patches/@docusaurus-core-npm-2.0.0-beta.6-8177d2ee39"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
