{
  "name": "design-system",
  "version": "1.0.0",
  "private": true,
  "description": "Coinbase design system",
  "repository": "git@github.cbhq.net:frontend/cds.git",
  "scripts": {
    "build.all": "yarn nx affected --target=build --all",
    "build.android": "yarn nx run mobile-playground:android",
    "build.common": "yarn nx run common:build",
    "build.css": "yarn nx run web:build-css",
    "build.fonts": "yarn nx run fonts:build",
    "build.ios": "yarn nx run mobile-playground:ios",
    "build.lottie": "yarn nx run lottie-files:build",
    "build.mobile": "yarn nx run mobile:build",
    "build.utils": "yarn nx run utils:build",
    "build.web": "yarn nx run web:build",
    "build.website": "yarn nx run website:build",
    "clean.android": "yarn nx run mobile-playground:start-android --clean",
    "clean.ios": "yarn nx run mobile-playground:start-ios --clean",
    "codegen": "yarn nx run codegen:codegen && yarn codegen.docs && yarn lint.all --skip-nx-cache && yarn format.all --skip-nx-cache && yarn stylelint.all --skip-nx-cache && ",
    "codegen.changelog": "yarn nx run codegen:changelog",
    "codegen.contributing": "yarn nx run codegen:contributing",
    "codegen.docs": "yarn nx run codegen:docgen && yarn lint.website --fix && yarn format.website",
    "codegen.icons": "yarn nx run codegen:build_icons",
    "codegen.illustrations": "yarn nx run codegen:build_illustrations",
    "codegen.routes": "yarn nx run codegen:prepare_mobile_routes",
    "codegen.release": "nx run codegen:release",
    "format.all": "yarn nx affected --target=format --all",
    "format.common": "yarn nx format common",
    "format.icons": "yarn svgo packages/codegen/icons/svg/*.svg --config=packages/codegen/configs/svgo.config.js",
    "format.mobile": "yarn nx format mobile",
    "format.playground": "yarn nx format mobile-playground",
    "format.utils": "yarn nx format utils",
    "format.web": "yarn nx format web",
    "format.website": "yarn nx format website",
    "lint.all": "yarn nx affected --target=lint --all",
    "lint.common": "yarn nx lint common",
    "lint.mobile": "yarn nx lint mobile",
    "lint.utils": "yarn nx lint utils",
    "lint.web": "yarn nx lint web",
    "lint.website": "yarn nx lint website",
    "lint.fix": "yarn lint.all --fix",
    "prepare.adoption": "yarn nx run codegen:prepare_adoption",
    "prepare.icons": "yarn sync.icons && yarn format.icons && yarn codegen.icons && yarn codegen.docs",
    "prepare.illustrations": "yarn codegen.illustration && yarn codegen.docs",
    "release": "yarn codegen.release && yarn codegen.changelog && yarn codegen.contributing && yarn codegen.docs",
    "start.android": "yarn codegen.routes && yarn nx run mobile-playground:start-android",
    "start.ios": "yarn codegen.routes && yarn nx run mobile-playground:start-ios",
    "start.metro": "yarn nx run mobile-playground:start-metro",
    "start.story": "cd apps/storybook; yarn start-storybook",
    "start.website": "cd apps/website; yarn docusaurus start --port 3000",
    "stylelint.all": "yarn nx affected --target=lint-styles --all",
    "stylelint.common": "yarn nx lint-styles common",
    "stylelint.web": "yarn nx lint-styles web",
    "stylelint.website": "yarn nx lint-styles website",
    "stylelint.fix": "yarn stylelint.all --fix",
    "test.all": "yarn nx affected --target=test --all",
    "sync.icons": "yarn nx run codegen:sync_icons",
    "test.common": "cd packages/common; jest",
    "test.mobile": "cd packages/mobile; jest",
    "test.web": "cd packages/web; jest",
    "test.utils": "cd packages/utils; jest",
    "typecheck.all": "yarn nx affected --target=typecheck --all",
    "typecheck.common": "yarn nx typecheck common",
    "typecheck.mobile": "yarn nx typecheck mobile",
    "typecheck.web": "yarn nx typecheck web",
    "typecheck.utils": "yarn nx typecheck utils",
    "validate": "yarn nx workspace-lint",
    "codeowners": "mono-pipeline sync-codeowners",
    "setup": "./setup.sh",
    "setup-env": "mono-env setup --group common web",
    "diagnose": "mono-env diagnose --group common web"
  },
  "resolutions": {
    "colors": "1.4.0",
    "coa": "2.0.2",
    "@docusaurus/core@2.0.0-beta.6": "patch:@docusaurus/core@npm:2.0.0-beta.6#.yarn/patches/@docusaurus-core-npm-2.0.0-beta.6-8177d2ee39"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@babel/cli": "^7.14.3",
    "@babel/core": "^7.14.3",
    "@babel/parser": "^7.14.4",
    "@babel/plugin-external-helpers": "^7.12.13",
    "@babel/plugin-proposal-class-properties": "^7.10.4",
    "@babel/plugin-proposal-object-rest-spread": "^7.10.4",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/preset-env": "^7.14.4",
    "@babel/preset-react": "^7.13.13",
    "@babel/preset-typescript": "^7.12.7",
    "@babel/register": "^7.14.5",
    "@babel/runtime": "^7.14.0",
    "@babel/template": "^7.12.7",
    "@babel/types": "^7.14.4",
    "@cbhq/eslint-plugin": "^1.5.0",
    "@cbhq/jest-preset": "^0.1.3",
    "@cbhq/jest-preset-mobile": "^0.1.10",
    "@cbhq/mono-env": "^0.1.6",
    "@cbhq/mono-pipeline": "^0.2.1",
    "@cbhq/mono-tasks": "^0.1.26",
    "@cbhq/mono-templates": "^0.1.5",
    "@nrwl/cli": "^13.8.2",
    "@nrwl/tao": "^13.8.2",
    "@nrwl/workspace": "^13.8.2",
    "@testing-library/react": "^11.2.5",
    "@testing-library/react-hooks": "^3.7.0",
    "@testing-library/react-native": "^7.1.0",
    "@types/d3-array": "^2.9.0",
    "@types/d3-color": "^2.0.1",
    "@types/d3-interpolate-path": "^2.0.0",
    "@types/d3-scale": "^3.2.2",
    "@types/d3-selection": "^1.4.3",
    "@types/d3-shape": "^2.0.0",
    "@types/d3-transition": "^1.3.2",
    "@types/dotenv-webpack": "^7.0.3",
    "@types/ejs": "^3.0.4",
    "@types/humps": "^2.0.0",
    "@types/intl": "^1.2.0",
    "@types/jest-axe": "^3.5.1",
    "@types/lodash": "^4.14.178",
    "@types/mini-css-extract-plugin": "^2.2.0",
    "@types/node": "^14.0.14",
    "@types/react": "^17.0.3",
    "@types/react-dom": "^17.0.2",
    "@types/react-is": "^17.0.2",
    "@types/react-native": "^0.66.8",
    "@types/react-router-dom": "^5.1.5",
    "@types/react-virtualized": "^9.21.13",
    "@types/semver": "7.3.4",
    "@types/svgo": "^2.3.0",
    "@types/url-parse": "^1.4.3",
    "@types/yargs": "^15.0.5",
    "axios": "^0.18.0",
    "babel-loader": "^8.2.2",
    "babel-plugin-dotenv-import": "^2.2.0",
    "babel-plugin-module-resolver": "^4.1.0",
    "babel-plugin-replace-ts-export-assignment": "^0.0.2",
    "chalk": "^4.1.2",
    "dotenv-webpack": "7.0.3",
    "eslint": "^8.7.0",
    "execa": "^5.1.1",
    "fast-glob": "^3.2.5",
    "jest": "^27.4.7",
    "jest-axe": "^4.1.0",
    "prettier": "^2.5.1",
    "react-test-renderer": "^17.0.2",
    "stylelint": "^13.6.1",
    "stylelint-a11y": "^1.2.3",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-recommended": "^3.0.0",
    "stylelint-high-performance-animation": "^1.5.2",
    "stylelint-no-unsupported-browser-features": "^4.0.0",
    "stylelint-prettier": "^1.1.2",
    "svgo": "^2.3.0",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^3.9.0",
    "type-fest": "1.2.0",
    "typescript": "~4.5.4",
    "url-loader": "4.1.1",
    "webfont": "9.0.0",
    "webpack": "^5.63.0",
    "webpack-bundle-analyzer": "4.4.2",
    "webpack-cli": "^4.7.2",
    "webpack-dev-server": "^3.11.0",
    "yargs": "^15.3.1"
  },
  "engines": {
    "node": "16.13.*"
  },
  "packageManager": "yarn@3.1.0"
}
