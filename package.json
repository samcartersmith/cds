{
  "name": "design-system",
  "version": "1.0.0",
  "private": true,
  "description": "Coinbase design system",
  "repository": "git@github.cbhq.net:jonathan-rossi/design-system.git",
  "scripts": {
    "postinstall": "patch-package",
    "build": "packemon build --filter '@cbhq/*'",
    "diagnose": "yarn build && mono-env diagnose --group web",
    "setup": "yarn build && mono-env setup --group web",
    "validate": "nx workspace-lint"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@cbhq/eslint-plugin": "^1.4.0",
    "@cbhq/jest-preset": "^0.1.0",
    "@cbhq/mono-env": "^0.1.0",
    "@cbhq/mono-pipeline": "^0.1.0",
    "@cbhq/mono-tasks": "^0.1.0",
    "@cbhq/mono-templates": "^0.1.0",
    "@nrwl/cli": "^13.4.3",
    "@nrwl/tao": "^13.4.3",
    "@nrwl/workspace": "^13.4.3",
    "@types/node": "^16.11.19",
    "eslint": "^8.7.0",
    "jest": "^27.4.7",
    "packemon": "^1.10.0",
    "patch-package": "^6.4.7",
    "prettier": "^2.5.1",
    "typescript": "~4.5.4"
  },
  "engines": {
    "node": "16.13.*"
  },
  "packageManager": "yarn@3.1.0"
}
