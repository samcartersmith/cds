{
  "name": "design-system",
  "version": "1.0.0",
  "private": true,
  "description": "Coinbase design system",
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git"
  },
  "scripts": {
    "changelog": "mono-pipeline version",
    "clean-nx-dir": "rm -rf .nx || true",
    "clean-packemon-outs": "rm -rf packages/*/{dts,lib,esm,cjs} || true",
    "clean-dist-outs": "rm -rf packages/*/dist || true",
    "reset-nx-daemon": "nx reset",
    "clean": "yarn clean-nx-dir && yarn clean-packemon-outs && yarn clean-dist-outs && yarn reset-nx-daemon",
    "clean-expo": "rm -rf apps/mobile-app/ios && rm -rf apps/mobile-app/.expo",
    "build-required-packages": "yarn nx run cds-tasks:build",
    "codeowners": "mono-pipeline sync-codeowners",
    "diagnose": "mono-env diagnose --group common web mobile",
    "setup": "yarn build-required-packages && mono-env setup --group common web mobile",
    "release": "yarn mono-pipeline validate-versioned --projectsWithNoSrcFolder='web,mobile,common' && yarn nx run codegen:updatePkgsForGenericBump && yarn nx run codegen:updateWebsiteChangelogs && yarn nx run cds-tasks:validate-website-changelog-updates && yarn nx run cds-tasks:validate-cds-versions",
    "reset-changelogs": "yarn node tools/resetChangelogs.mjs"
  },
  "resolutions": {
    "colors": "1.4.0",
    "coa": "2.0.2",
    "yargs-parser": "^21.0.1",
    "react-router-dom": "^5.2.0",
    "ejs": "^3.1.7",
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@testing-library/user-event@^14.0.4": "patch:@testing-library/user-event@npm:14.0.4#.yarn/patches/@testing-library-user-event-npm-14.0.4-109d618170",
    "@docusaurus/plugin-content-docs@2.0.0-beta.18": "patch:@docusaurus/plugin-content-docs@npm:2.0.0-beta.18#.yarn/patches/@docusaurus-plugin-content-docs-npm-2.0.0-beta.18-48b9b95b87",
    "@babel/plugin-proposal-private-property-in-object": "^7.12.1",
    "eslint-config-next": "13.4.18",
    "eslint-plugin-react-hooks": "4.6.0",
    "framer-motion@^10.18.0": "patch:framer-motion@npm:10.18.0#.yarn/patches/framer-motion-npm-10.18.0-ae9ea02138"
  },
  "resolutionComments": {
    "colors": "Main package was polluted by the original author. https://github.com/Marak/colors.js/issues/317",
    "coa": "This package was hijacked. 2.0.2 was the last stable release.",
    "yargs-parser": "Vulnerability fix for url-parser. (https://github.cbhq.net/frontend/cds/pull/267)",
    "react-router-dom": "Docusaurus is still on 5.2, cannot update yet. (https://github.cbhq.net/frontend/cds/pull/765)",
    "ejs": "Vulnerability Fix. https://www.cve.org/CVERecord?id=CVE-2022-29078",
    "@types/react": "Keep all react types used in repo on a single version. (https://github.cbhq.net/frontend/cds/pull/1775)",
    "@types/react-dom": "Keep all react types used in repo on a single version. (https://github.cbhq.net/frontend/cds/pull/1775)",
    "@testing-library/user-event@^14.0.4": "Create subpath export for types. (https://github.cbhq.net/frontend/cds/pull/497)",
    "@docusaurus/plugin-content-docs@2.0.0-beta.18": "Creating subpath export for options. (https://github.cbhq.net/frontend/cds/pull/575)",
    "@babel/plugin-proposal-private-property-in-object": "Temporary fix for babel v7.22.5 until packemon declares @babel/plugin-proposal-private-property-in-object as required. (https://github.cbhq.net/frontend/cds/pull/2027)",
    "eslint-config-next": "Fix error: TypeError: services.getTypeAtLocation is not a function in nextjs lint. known issue with eslint upgrade: https://github.com/vercel/next.js/issues/52890",
    "eslint-plugin-react-hooks": "Fix error: ESLint couldn't determine the plugin 'react-hooks' uniquely in nextjs lint. known issue eslint upgrade: https://github.com/vercel/next.js/issues/52365",
    "framer-motion@^10.18.0": "Export missing types"
  },
  "workspaces": [
    "apps/*",
    "libs/*",
    "packages/*"
  ],
