import * as React from 'react';

import { TextProps } from '@cb/design-system-web/components/Text/TextProps';
import * as styles from '@cb/design-system-web/primitives/typography/styles';
import { css, cx } from 'linaria';

export type { TextProps }

const noLineWrap = css`
  white-space: nowrap;
`;

const tabularNumber = css`
  font-feature-settings: 'tnum';
`;

<% Object.entries(typography).forEach(([name, { tag, fontFamily, tnum = false }]) => { %>
    export const Text<%- name %>: React.FC<TextProps> = React.memo(function Text<%- name %>({
        children,
        color,
        display,
        textAlign = 'start',
        wrap = false,
        tnum = <%- tnum %>,
        as <%_ if (!tag.startsWith('h')) { _%> : Tag = '<%- tag %>' <%_ } _%>
    }) {
        <% if (tag.startsWith('h')) { %> const Tag = as || '<%- tag %>' <% } %>

        return (
            <Tag
                style={{ display, color, textAlign }}
                className={cx(
                    styles.<%- fontFamily.toLowerCase() %>,
                    styles.<%- name.toLowerCase() %>,
                    !wrap && noLineWrap,
                    tnum && tabularNumber
                )}
            >
               {children}
            </Tag>
        );
    });
<% }) %>