import * as React from 'react';

import { TextProps } from '@cb/design-system-web/components/Text/TextProps';
import * as styles from '@cb/design-system-web/primitives/typography/styles';
import { css, cx } from 'linaria';

const noLineWrap = css`
  white-space: nowrap;
`;

const tabularNumber = css`
  font-feature-settings: 'tnum';
`;

<% Object.entries(typographies).forEach(([name, { tag, tnum = false }]) => { %>
    export const Text<%- name %>: React.FC<
        <% if (!tag.startsWith('h')) { %> TextProps <% } else { %> Omit<TextProps, 'as'> <% }%>
    > = React.memo(function Text<%- name %>({
        children,
        color,
        display = 'initial',
        textAlign = 'start',
        noWrap = false,
        tnum = <%- tnum %>,
        <% if (!tag.startsWith('h')) { %> as: Tag = '<%- tag %>', <% } %>
    }) {
        return (
            <<% if (!tag.startsWith('h')) { %> Tag <% } else { %> <%- tag %> <% } %>
                style={{ display, color, textAlign }}
                className={cx(
                    styles.<%- name.toLowerCase() %>,
                    noWrap && noLineWrap,
                    tnum && tabularNumber
                )}
            >
               {children}
            </<% if (!tag.startsWith('h')) { %> Tag <% } else { %> <%- tag %> <% } %>>
        );
    });
<% }) %>