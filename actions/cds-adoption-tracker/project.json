{
  "name": "cds-adoption-tracker",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "actions/cds-adoption-tracker/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "command": "git clean -fde '!dist' && ncc build src/action.ts --transpile-only"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "{projectRoot}/jest.config.js"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "dev",
      "configurations": {
        "dev": {
          "command": "tsc --build --pretty --verbose"
        },
        "prod": {
          "command": "tsc --build ./tsconfig.build.json --pretty --verbose"
        }
      }
    }
  }
}
