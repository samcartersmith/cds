{
  "npmScope": "cbhq",
  "affected": {
    "defaultBase": "master"
  },
  "cli": {
    "defaultCollection": "@nrwl/workspace",
    "packageManager": "yarn"
  },
  "implicitDependencies": {
    ".buildkite/*.yml": "*",
    ".eslintrc.js": "*",
    ".*ignore": "*",
    "*.config.js": "*",
    "nx.json": "*",
    "package.json": {
      "dependencies": "*",
      "devDependencies": "*"
    },
    "tsconfig.json": "*",
    "tsconfig.*.json": "*",
    "workspace.json": "*"
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "@nrwl/workspace/tasks-runners/default",
      "options": {
        "cacheDirectory": "./.nx/cache",
        "cacheableOperations": [
          "a11y-web",
          "build",
          "build-css",
          "build-esm",
          "build-for-tests",
          "lint",
          "lint-styles",
          "test",
          "typecheck",
          "e2e",
          "visreg"
        ],
        "captureStderr": true
      }
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ]
    },
    "start": {
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ]
    }
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  }
}
