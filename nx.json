{
  "npmScope": "cbhq",
  "affected": {
    "defaultBase": "master"
  },
  "cli": {
    "defaultCollection": "@nrwl/workspace",
    "packageManager": "yarn"
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "@nrwl/workspace/tasks-runners/default",
      "options": {
        "cacheDirectory": "./.nx/cache",
        "cacheableOperations": [
          "a11y-web",
          "build",
          "build-css",
          "build-esm",
          "build-for-tests",
          "lint",
          "lint-styles",
          "test",
          "typecheck",
          "e2e",
          "visreg"
        ],
        "captureStderr": true
      }
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "start": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    }
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [
      "{workspaceRoot}/.buildkite/*.yml",
      "{workspaceRoot}/.eslintrc.js",
      "{workspaceRoot}/.*ignore",
      "{workspaceRoot}/*.config.js",
      "{workspaceRoot}/nx.json",
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/tsconfig.json",
      "{workspaceRoot}/tsconfig.*.json",
      "{workspaceRoot}/workspace.json"
    ],
    "production": ["default"]
  }
}
