{
  "npmScope": "cbhq",
  "affected": {
    "defaultBase": "master"
  },
  "cli": {
    "packageManager": "yarn"
  },
  "tasksRunnerOptions": {
    "default": {
      "runner": "@cbhq/nx-tasks-runner",
      "options": {
        "cacheDirectory": "./.nx/cache",
        "cacheableOperations": [
          "a11y-web",
          "build",
          "build-css",
          "build-for-tests",
          "format",
          "lint",
          "lint-styles",
          "test",
          "typecheck"
        ],
        "captureStderr": true
      }
    }
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build",
        "export-package-version"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{workspaceRoot}/.nx/outs/projects/{projectRoot}",
        "{projectRoot}/assets",
        "{projectRoot}/cjs",
        "{projectRoot}/dts",
        "{projectRoot}/esm",
        "{projectRoot}/lib",
        "{projectRoot}/mjs"
      ]
    },
    "start": {
      "inputs": [
        "production",
        "^production"
      ]
    },
    "lint": {
      "inputs": [
        "default",
        "^production",
        "{workspaceRoot}/.eslintignore"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "default",
        "^production"
      ],
      "outputs": [
        "{workspaceRoot}/.nx/outs/projects/{projectRoot}/coverage"
      ]
    },
    "typecheck": {
      "inputs": [
        "default",
        "^production"
      ],
      "outputs": [
        "{workspaceRoot}/.nx/dts/{projectRoot}"
      ]
    }
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/.buildkite/*.yml",
      "{workspaceRoot}/.eslintrc.js",
      "{workspaceRoot}/.*ignore",
      "{workspaceRoot}/*.config.js",
      "{workspaceRoot}/nx.json",
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/tsconfig.json",
      "{workspaceRoot}/tsconfig.*.json"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)"
    ]
  },
  "$schema": "./node_modules/nx/schemas/nx-schema.json"
}
