{
  "compilerOptions": {
    "strict": true,
    "allowJs": true,
    "experimentalDecorators": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "lib": [
      "dom",
      "esnext"
    ],
    "jsx": "react-jsx",
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "module": "CommonJS",
    "target": "ES6",
    "baseUrl": ".",
    "paths": {}
  },
  "include": []
}
