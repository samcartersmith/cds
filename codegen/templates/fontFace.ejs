<%_ data.fonts.map(value => { _%>
    @font-face {
        font-display: swap;
        font-family: '<%- value %>';
        src: url('./<%- value %>-Regular.woff2') format('woff2');
        font-weight: 400;
    }
    @font-face {
        font-display: swap;
        font-family: '<%- value %>';
        src: url('./<%- value %>-Medium.woff2') format('woff2');
        font-weight: 500 800;
      }
<%_ }) _%>

<% Object.entries(data.css).map(([name, styles]) => { %>
    <%- name %> {
      <%_ Object.entries(styles).map(([key, value]) => { _%>
        <%- key %>:  <%- value %>;
      <%_ }) _%>
    }
<% }) %>