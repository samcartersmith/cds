<%_ data.map(item => { _%>
import <%- item %> from './theme-<%- item %>';
<%_ }) _%>
import { mergeThemeConfigs } from './mergeThemeConfigs';
import { ThemeConfig } from '../types';

export const baseTheme: ThemeConfig = {
  light: base.light,
  dark: { ...base.dark, palette: base.light.palette },
};

<%_ data.filter(item => item !== 'base').map(item => { _%>
export const <%- item %>Theme = mergeThemeConfigs(baseTheme, <%- item %>);
<%_ }) _%>
