import { css } from 'linaria';

import { palette } from '../styles/palette';

export const lottieStyles = css`
<% Object.keys(data).map(paletteAlias => { %>
  .palette_<%- paletteAlias %> {
    &_stroke {
      stroke: ${palette.<%- paletteAlias %>};
    }
    &_fill {
      fill: ${palette.<%- paletteAlias %>};
    }
  }
<%_ }) _%>
`;
