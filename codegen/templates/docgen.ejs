---
id: <%- data.id %>
title: <%- data.componentName %>
---

import { ApiDetails } from "@cbhq/cds-website/components/ApiDetails";
import { Badge } from "@cbhq/cds-website/components/Badge";
import { ComponentDetails } from "@cbhq/cds-website/components/ComponentDetails";

<ComponentDetails componentName="<%- data.componentName %>" templateName="intro" />

## Props

<%_ data.props.map(({ heading, name, description, link, defaultValue, required, danger, mobileOptions, webOptions }) => { _%>
### <%- heading %>


<%- description %>
<%- danger %>
<% if (link){ %>
**<%- link %>**
<% } %>


<ApiDetails
  componentName="<%- data.componentName %>"
  propertyName="<%- name %>"
  required={<%- required %>}
  defaultValue="<%- defaultValue %>"
  mobileOptions={<%- JSON.stringify(mobileOptions) %>}
  webOptions={<%- JSON.stringify(webOptions) %>}
/>

<ComponentDetails componentName="<%- data.componentName %>" templateName="<%- name %>" />

<% }) %>

<ComponentDetails componentName="<%- data.componentName %>" templateName="outro" />
