<% const pullPaletteToConst = data.config.light && data.config.dark && data.config.light.palette === data.config.dark.palette; %>
<% const isBaseTheme = data.name === 'base'; %>
import { ThemeConfig } from '../types';
<% if (!isBaseTheme){ %>
import { mergeThemeConfigs } from '../system/mergeThemeConfigs';
import { themeBase } from './themeBase';
<%_ } _%> 

<% if (pullPaletteToConst){ %>
const palette = <%- JSON.stringify(data.config.light.palette) -%> as const;
<%_ } _%> 

const config = {
  name: '<%- data.name %>',
  <% if (data.config.light){ -%>
  light: {
    <% if (pullPaletteToConst){ %>
    palette,
    <% }else{ %>
    palette: <%- JSON.stringify(data.config.light.palette) -%>,
    <%_ } _%> 
    rgbaStrings: <%- JSON.stringify(data.config.light.rgbaStrings) -%>,
    hexValues: <%- JSON.stringify(data.config.light.hexValues) -%>,
    interactableTokens: <%- JSON.stringify(data.config.light.interactableTokens) -%>,
    name: '<%- data.name %>-light',
  },
  <%_ } _%> 
  <% if (data.config.dark){ -%>
  dark: { 
    <% if (pullPaletteToConst){ %>
    palette,
    <% }else{ %>
    palette: <%- JSON.stringify(data.config.dark.palette) -%>,
    <%_ } _%> 
    rgbaStrings: <%- JSON.stringify(data.config.dark.rgbaStrings) -%>,
    hexValues: <%- JSON.stringify(data.config.dark.hexValues) -%>,
    interactableTokens: <%- JSON.stringify(data.config.dark.interactableTokens) -%>,
    name: '<%- data.name %>-dark',
   },
   <%_ } _%> 
} as const;

<% if (isBaseTheme){ %>
export const <%- data.fileName %>: ThemeConfig = config; 
<% }else{ %>
export const <%- data.partialName %> = config;
export const <%- data.fileName %>: ThemeConfig = mergeThemeConfigs(themeBase, config);
<%_ } _%> 