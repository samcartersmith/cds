{
  "name": "@cds/mobile-playground",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build.android": "nx run mobile-playground:build-android",
    "build.ios": "nx run mobile-playground:build-ios",
    "clean.android": "nx run mobile-playground:start-android --clean",
    "clean.ios": "nx run mobile-playground:start-ios --clean",
    "format": "nx run mobile-playground:format",
    "lint": "nx run mobile-playground:lint",
    "lint.fix": "nx run mobile-playground:lint --fix",
    "start": "nx run codegen:prepare_mobile_routes && nx run mobile-playground:start-ios",
    "start.android": "nx run codegen:prepare_mobile_routes && nx run mobile-playground:start-android",
    "start.ios": "nx run codegen:prepare_mobile_routes && nx run mobile-playground:start-ios",
    "start.metro": "nx run mobile-playground:start-metro",
    "typecheck": "nx run mobile-playground:typecheck",
    "visreg:finalize": "percy build:finalize"
  },
  "dependencies": {
    "@cbhq/cds-common": "workspace:*",
    "@cbhq/cds-mobile": "workspace:*",
    "@react-native-community/cli": "^6.3.1",
    "@react-native-community/cli-platform-android": "^6.3.0",
    "@react-native-community/cli-platform-ios": "^6.2.0",
    "@react-native-community/masked-view": "^0.1.10",
    "@react-navigation/native": "^5.9.8",
    "@react-navigation/stack": "^5.12.8",
    "intl": "^1.2.5",
    "react": "^17.0.2",
    "react-native": "0.66.3",
    "react-native-codegen": "^0.0.11",
    "react-native-config": "^1.4.5",
    "react-native-gesture-handler": "^1.9.0",
    "react-native-reanimated": "^2.9.1",
    "react-native-screens": "^3.12.0"
  },
  "devDependencies": {
    "@cbhq/detox-utils": "^0.2.2",
    "@percy/cli": "^1.2.1",
    "@percy/client": "^1.2.1",
    "@percy/sdk-utils": "^1.2.1",
    "@percy/storybook": "^4.2.1",
    "detox": "^19.7.1",
    "jest": "27.2.5",
    "lottie-ios": "3.2.3",
    "lottie-react-native": "^5.0.1",
    "react-native-inappbrowser-reborn": "3.6.3",
    "react-native-linear-gradient": "2.5.6",
    "react-native-navigation-bar-color": "2.0.1",
    "react-native-safe-area-context": "^3.2.0",
    "react-native-svg": "12.1.0"
  }
}
