{
  "root": "apps/mobile-playground",
  "sourceRoot": "apps/mobile-playground/src",
  "projectType": "application",
  "targets": {
    "start-android": {
      "executor": "@cbhq/mono-tasks:start-android"
    },
    "build-android": {
      "executor": "@cbhq/mono-tasks:build-android"
    },
    "start-ios": {
      "executor": "@cbhq/mono-tasks:start-ios"
    },
    "build-ios": {
      "executor": "@cbhq/mono-tasks:build-ios"
    },
    "start-metro": {
      "executor": "@cbhq/mono-tasks:start-metro"
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "typecheck": {
      "executor": "@cbhq/cds-tools:typecheck"
    },
    "build-ios-e2e": {
      "executor": "@cbhq/mono-tasks:build-ios",
      "outputs": ["ios/build"],
      "options": {
        "buildType": "e2e",
        "detoxConfig": "ios.release"
      },
      "configurations": {
        "debug": {
          "detoxConfig": "ios.debug"
        }
      }
    },
    "ios-e2e": {
      "executor": "@cbhq/mono-tasks:test-detox",
      "options": {
        "config": "ios.release",
        "record": true
      },
      "configurations": {
        "ci": {},
        "debug": {
          "config": "ios.debug",
          "debug": true,
          "detoxArgs": ["--debug-synchronization", "500"]
        }
      }
    },
    "run-ios-e2e": {
      "executor": "@cbhq/cds-tools:run-conditional",
      "options": {
        "triggerProjects": ["mobile", "common", "utils", "fonts", "lottie-files"],
        "target": "mobile-playground:ios-e2e"
      }
    }
  },
  "tags": []
}
