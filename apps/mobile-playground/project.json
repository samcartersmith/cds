{
  "name": "mobile-playground",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/mobile-playground/src",
  "projectType": "application",
  "targets": {
    "start-android": {
      "executor": "@cbhq/mono-tasks-mobile:start-android",
      "dependsOn": ["^build", "^mobile-routes"]
    },
    "build-android": {
      "executor": "@cbhq/mono-tasks-mobile:build-android",
      "dependsOn": ["^build"]
    },
    "start-ios": {
      "executor": "@cbhq/mono-tasks-mobile:start-ios",
      "dependsOn": ["^build", "^mobile-routes"]
    },
    "build-ios": {
      "executor": "@cbhq/mono-tasks-mobile:build-ios",
      "dependsOn": ["^build"]
    },
    "start-metro": {
      "executor": "@cbhq/mono-tasks-mobile:start-metro"
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "visreg": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "buildkite-agent pipeline upload .buildkite/visreg-ios.yml",
          "buildkite-agent pipeline upload .buildkite/visreg-android.yml"
        ],
        "parallel": true
      },
      "dependsOn": ["^build"]
    },
    "build-ios-e2e": {
      "executor": "@cbhq/mono-tasks-mobile:build-ios",
      "outputs": ["{projectRoot}/ios/build"],
      "options": {
        "buildType": "e2e",
        "detoxConfig": "ios.release"
      },
      "configurations": {
        "debug": {
          "detoxConfig": "ios.debug"
        }
      },
      "dependsOn": ["^build"]
    },
    "ios-e2e": {
      "executor": "@cbhq/mono-tasks:test-detox",
      "options": {
        "config": "ios.release",
        "record": true
      },
      "configurations": {
        "ci": {},
        "debug": {
          "config": "ios.debug",
          "debug": true,
          "detoxArgs": ["--debug-synchronization", "500"]
        }
      },
      "dependsOn": ["^build"]
    },
    "build-android-e2e": {
      "executor": "@cbhq/mono-tasks-mobile:build-android",
      "outputs": ["{projectRoot}/android/build", "{projectRoot}/android/app/build"],
      "options": {
        "buildType": "e2e",
        "clean": true,
        "detoxConfig": "android.functionalTest"
      },
      "configurations": {
        "debug": {
          "detoxConfig": "android.debug"
        }
      },
      "dependsOn": ["^build"]
    },
    "android-e2e": {
      "executor": "@cbhq/mono-tasks:test-detox",
      "options": {
        "config": "android.functionalTest",
        "detoxArgs": ["--device-name", "Pixel_3a_API_30"],
        "record": true
      },
      "configurations": {
        "ci": {
          "detoxArgs": [
            "--device-name",
            "Pixel_3a_API_30",
            "--device-boot-args='-skin 1080x1920'",
            "--headless"
          ]
        },
        "debug": {
          "config": "android.debug"
        }
      },
      "dependsOn": ["^build"]
    },
    "android-e2e-emulator": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "$ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager --verbose 'system-images;android-30;default;x86_64'",
          "echo no | $ANDROID_HOME/cmdline-tools/latest/bin/avdmanager --verbose create avd --force --name Pixel_3a_API_30 --package 'system-images;android-30;default;x86_64'"
        ],
        "parallel": false
      },
      "configurations": {
        "m1": {
          "commands": [
            "$ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager --verbose 'system-images;android-30;default;arm64-v8a'",
            "echo no | $ANDROID_HOME/cmdline-tools/latest/bin/avdmanager --verbose create avd --force --name Pixel_3a_API_30 --package 'system-images;android-30;default;arm64-v8a'"
          ]
        }
      }
    },
    "prebuild-android-e2e": {
      "executor": "@cbhq/mono-tasks-mobile:prebuild",
      "options": {
        "platform": "android",
        "buildType": "e2e",
        "arch": "universal"
      },
      "dependsOn": ["^build"]
    },
    "prebuild-ios-e2e": {
      "executor": "@cbhq/mono-tasks-mobile:prebuild",
      "options": {
        "platform": "ios",
        "buildType": "e2e",
        "arch": "simulator_x86"
      },
      "dependsOn": ["^build"]
    }
  },
  "tags": []
}
