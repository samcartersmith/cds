{
  "root": "apps/mobile-playground",
  "sourceRoot": "apps/mobile-playground/src",
  "projectType": "application",
  "targets": {
    "start-android": {
      "executor": "@cbhq/mono-tasks:start-android"
    },
    "build-android": {
      "executor": "@cbhq/mono-tasks:build-android"
    },
    "start-ios": {
      "executor": "@cbhq/mono-tasks:start-ios"
    },
    "build-ios": {
      "executor": "@cbhq/mono-tasks:build-ios"
    },
    "start-metro": {
      "executor": "@cbhq/mono-tasks:start-metro"
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "typecheck": {
      "executor": "@cbhq/cds-tools:typecheck"
    },
    "build-ios-e2e": {
      "executor": "@cbhq/mono-tasks:build-ios",
      "outputs": ["ios/build"],
      "options": {
        "buildType": "e2e",
        "detoxConfig": "ios.release"
      },
      "configurations": {
        "debug": {
          "detoxConfig": "ios.debug"
        }
      }
    },
    "ios-e2e": {
      "executor": "@cbhq/mono-tasks:test-detox",
      "options": {
        "config": "ios.release",
        "record": true
      },
      "configurations": {
        "ci": {},
        "debug": {
          "config": "ios.debug",
          "debug": true,
          "detoxArgs": ["--debug-synchronization", "500"]
        }
      }
    },
    "run-ios-e2e": {
      "executor": "@cbhq/cds-tools:run-conditional",
      "options": {
        "triggerProjects": [
          "mobile-playground",
          "mobile",
          "common",
          "utils",
          "fonts",
          "lottie-files"
        ],
        "target": "mobile-playground:ios-e2e"
      }
    },
    "run-android-e2e": {
      "executor": "@cbhq/cds-tools:run-conditional",
      "options": {
        "triggerProjects": [
          "mobile-playground",
          "mobile",
          "common",
          "utils",
          "fonts",
          "lottie-files"
        ],
        "target": "mobile-playground:e2e-android"
      }
    },
    "build-android-e2e": {
      "executor": "@cbhq/mono-tasks:build-android",
      "outputs": ["android/build", "android/app/build"],
      "options": {
        "buildType": "e2e",
        "detoxConfig": "android.functionalTest"
      },
      "configurations": {
        "debug": {
          "detoxConfig": "android.debug"
        }
      },
      "dependsOn": [
        {
          "target": "dist",
          "projects": "dependencies"
        }
      ]
    },
    "e2e-android": {
      "executor": "@cbhq/mono-tasks:test-detox",
      "options": {
        "config": "android.functionalTest",
        "detoxArgs": ["--device-name", "Pixel_3a_API_30"],
        "record": true
      },
      "configurations": {
        "ci": {
          "detoxArgs": [
            "--device-name",
            "Pixel_3a_API_30",
            "--device-boot-args='-skin 1080x1920'",
            "--headless"
          ]
        },
        "debug": {
          "config": "android.debug"
        }
      }
    },
    "e2e-android-emulator": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": [
          "$ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager --verbose 'system-images;android-30;google_apis;x86'",
          "echo no | $ANDROID_HOME/cmdline-tools/latest/bin/avdmanager --verbose create avd --force --name Pixel_3a_API_30 --package 'system-images;android-30;google_apis;x86'"
        ],
        "parallel": false
      },
      "configurations": {
        "m1": {
          "commands": [
            "$ANDROID_HOME/cmdline-tools/latest/bin/sdkmanager --verbose 'system-images;android-30;google_apis;arm64-v8a'",
            "echo no | $ANDROID_HOME/cmdline-tools/latest/bin/avdmanager --verbose create avd --force --name Pixel_3a_API_30 --package 'system-images;android-30;google_apis;arm64-v8a'"
          ]
        }
      }
    }
  },
  "tags": []
}
