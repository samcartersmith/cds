{
  "name": "storybook2",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/storybook2",
  "projectType": "library",
  "tags": [],
  "targets": {
    "dev": {
      "command": "start-storybook"
    },
    "start": {
      "command": "start-storybook"
    },
    "build": {
      "command": "build-storybook --output-dir dist",
      "inputs": [
        "{projectRoot}/**/__stories__/**",
        "{projectRoot}/**/*.stories.*"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ]
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "percy": {
      "command": "tsx ./scripts/run-percy.ts",
      "dependsOn": [
        "build"
      ],
      "inputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "cwd": "apps/storybook2"
      }
    }
  }
}
