{
  "name": "cds-figma-sync",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/cds-figma-sync",
  "projectType": "library",
  "targets": {
    "dev": {
      "command": "ts-node-esm ./apps/cds-figma-sync/src/dev.ts",
      "dependsOn": [
        "^build"
      ]
    },
    "build": {
      "executor": "@cbhq/mono-tasks:build-package",
      "outputs": [
        "{projectRoot}/assets",
        "{projectRoot}/mjs"
      ]
    },
    "start": {
      "command": "node ./apps/cds-figma-sync/mjs/index.mjs",
      "dependsOn": [
        "build"
      ]
    },
    "dockerup": {
      "executor": "@cbhq/mono-tasks:run-package-script",
      "defaultConfiguration": "app",
      "configurations": {
        "app": {
          "script": "dockerup-app"
        },
        "static-assets": {
          "script": "dockerup-static-assets"
        },
        "trigger": {
          "script": "dockerup-trigger"
        }
      }
    },
    "dockerdown": {
      "executor": "@cbhq/mono-tasks:run-package-script",
      "options": {
        "script": "dockerdown"
      }
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    }
  }
}
