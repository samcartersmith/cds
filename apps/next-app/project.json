{
  "name": "next-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/next-app",
  "projectType": "application",
  "targets": {
    "dev": {
      "command": "next dev"
    },
    "build": {
      "command": "next build",
      "options": {
        "cwd": "apps/next-app"
      }
    },
    "start": {
      "command": "next dev",
      "options": {
        "cwd": "apps/next-app"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "{projectRoot}/jest.config.js"
      }
    },
    "typecheck": {
      "command": "tsc --build --pretty --verbose"
    },
    "report-disabled-eslint-rules": {
      "executor": "@cbhq/prevent-eslint-disable:report"
    }
  }
}
