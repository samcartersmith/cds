{
  "name": "next-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/next-app",
  "projectType": "application",
  "targets": {
    "dev": {
      "command": "next dev"
    },
    "build": {
      "command": "next build",
      "options": {
        "cwd": "apps/next-app"
      }
    },
    "analyze": {
      "executor": "@cbhq/mono-tasks:build-next",
      "env": {
        "ANALYZE": true
      }
    },
    "start": {
      "command": "next dev",
      "options": {
        "cwd": "apps/next-app"
      }
    },
    "extract": {
      "executor": "@cbhq/mono-tasks:extract-messages"
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "command": "next lint",
      "options": {
        "cwd": "apps/next-app"
      }
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "command": "tsc --build --pretty --verbose"
    },
    "report-disabled-eslint-rules": {
      "executor": "@cbhq/prevent-eslint-disable:report"
    }
  }
}
