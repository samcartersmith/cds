{
  "extends": [
    "../../.eslintrc.js"
  ],
  "overrides": [
    {
      "files": [
        "*.ts",
        "*.tsx"
      ],
      "rules": {
        "import/no-default-export": 0,
        "react/react-in-jsx-scope": "off",
        "import/no-extraneous-dependencies": "off"
      }
    },
    {
      "files": [
        "scripts/**/*.ts"
      ],
      "extends": [
        "plugin:@cbhq/node"
      ],
      "rules": {
        "no-restricted-globals": "off"
      }
    }
  ]
}
