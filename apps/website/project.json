{
  "name": "website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/website",
  "projectType": "application",
  "targets": {
    "adoption": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./scripts/adoption/main.ts",
        "NODE_OPTIONS": {
          "trace-deprecation": true,
          "abort-on-uncaught-exception": true,
          "max-old-space-size": 4096
        }
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/website",
        "commands": [
          "nx run docusaurus-plugin-docgen:watch",
          "nx run docusaurus-plugin-kbar:watch",
          "nx run docusaurus-theme:watch",
          "nx run docusaurus-preset:watch",
          "docusaurus start --port 3000"
        ]
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/website",
        "commands": [
          "docusaurus serve --dir ../../.nx/outs/projects/apps/website/docusaurus --port 3000"
        ]
      }
    },
    "build": {
      "executor": "@cbhq/mono-tasks:build-docusaurus"
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "@cbhq/mono-tasks:lint-styles"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    }
  }
}
