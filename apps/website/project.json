{
  "name": "website",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/website",
  "projectType": "application",
  "targets": {
    "dev": {
      "command": "docusaurus start --port 3000",
      "dependsOn": [
        "^build"
      ],
      "options": {
        "env": {
          "NODE_ENV": "development"
        }
      }
    },
    "start": {
      "command": "docusaurus serve --dir dist --port 3000",
      "dependsOn": [
        "build"
      ]
    },
    "build": {
      "command": "docusaurus build --out-dir dist"
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "@cbhq/mono-tasks:lint-styles"
    },
    "typecheck": {
      "command": "tsc --build --pretty --verbose"
    },
    "deprecations": {
      "command": "tsx ./scripts/deprecations/updateDeprecations.ts",
      "options": {
        "cwd": "apps/website"
      }
    },
    "adoption": {
      "command": "tsx ./scripts/adoption/main.ts",
      "dependsOn": [
        "^build"
      ],
      "options": {
        "cwd": "apps/website",
        "NODE_OPTIONS": {
          "trace-deprecation": true,
          "abort-on-uncaught-exception": true,
          "max-old-space-size": 4096
        }
      }
    },
    "generateAdoptionAndImpactReports": {
      "command": "tsx ./scripts/adoption/generateAdoptionAndImpactReports.ts",
      "options": {
        "cwd": "apps/website"
      }
    },
    "adoption-snowflake-upload": {
      "command": "ADOPTION_DIRECTORY=./static/data/__generated__ sh ./scripts/adoption/snowflake-upload.sh",
      "dependsOn": [
        "adoption"
      ],
      "options": {
        "cwd": "apps/website"
      }
    },
    "podium": {
      "command": "tsx ../../libs/cds-tasks/podium/impl.ts",
      "options": {
        "cwd": "apps/website"
      }
    },
    "a11y-lint-tracker": {
      "command": "tsx ../../libs/cds-tasks/a11y-lint-tracker/impl.ts",
      "options": {
        "cwd": "apps/website"
      }
    }
  }
}
