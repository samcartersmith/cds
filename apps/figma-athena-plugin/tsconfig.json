{
  "extends": "../../tsconfig.projectOptions.json",
  "compilerOptions": {
    "rootDir": "./",
    "module": "ES2015",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationDir": "dts",
    "typeRoots": [
      "../../node_modules/@figma",
    ],
  },
  "include": ["src"],
  "exclude": ["node_modules"],
  "references": [
    {
      "path": "../../packages/common"
    },
    {
      "path": "../../packages/web"
    },
    {
      "path": "../../packages/illustrations"
    },
    {
      "path": "../../packages/icons"
    },
    {
      "path": "../../packages/fonts"
    }
  ]
}
