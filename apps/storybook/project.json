{
  "root": "apps/storybook",
  "sourceRoot": "apps/storybook",
  "projectType": "library",
  "tags": [],
  "targets": {
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "@cbhq/cds-tools:lint-styles"
    },
    "typecheck": {
      "executor": "@cbhq/cds-tools:typecheck"
    },
    "build": {
      "executor": "@cbhq/mono-tasks:build-storybook"
    },
    "a11y": {
      "executor": "@cbhq/cds-tools:a11y",
      "dependsOn": [{ "target": "build", "projects": "self" }]
    },
    "percy": {
      "executor": "@cbhq/mono-tasks:run-percy",
      "dependsOn": [{ "target": "build", "projects": "self" }]
    },
    "run-a11y": {
      "executor": "@cbhq/cds-tools:run-conditional",
      "options": {
        "triggerProjects": ["web", "common", "utils", "fonts", "lottie-files"],
        "target": "storybook:a11y"
      }
    }
  }
}
