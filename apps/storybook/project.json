{
  "name": "storybook",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/storybook",
  "projectType": "library",
  "tags": [],
  "targets": {
    "start": {
      "executor": "@cbhq/mono-tasks:start-storybook"
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "@cbhq/mono-tasks:lint-styles"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    },
    "build": {
      "executor": "@cbhq/mono-tasks:build-storybook"
    },
    "build-for-tests": {
      "executor": "@cbhq/mono-tasks:build-storybook"
    },
    "a11y-web": {
      "executor": "@cbhq/mono-tasks:run-script",
      "options": {
        "script": "./scripts/run-a11y-tests.ts"
      },
      "dependsOn": [
        "build-for-tests"
      ]
    },
    "percy": {
      "executor": "@cbhq/mono-tasks:run-percy",
      "dependsOn": [
        "build-for-tests"
      ]
    },
    "serve-storybook": {
      "executor": "nx:run-commands",
      "cwd": "apps/storybook",
      "options": {
        "commands": [
          "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npx http-server /workdir/.nx/outs/projects/apps/storybook/storybook --port 6006 --silent\" \"wait-on tcp:6006 && yarn workspace @cds/storybook test-storybook --index-json\""
        ]
      }
    },
    "storybook-e2e-test": {
      "executor": "nx:run-commands",
      "cwd": "apps/storybook",
      "options": {
        "commands": [
          "npx playwright install-deps",
          "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"nx run storybook:build && npx http-server /workdir/.nx/outs/projects/apps/storybook/storybook --port 6006 --silent\" \"wait-on tcp:6006 && yarn workspace @cds/storybook test-storybook --index-json\""
        ]
      },
      "dependsOn": [
        "build-for-tests"
      ]
    }
  }
}
