{
  "name": "storybook",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/storybook",
  "projectType": "library",
  "tags": [],
  "targets": {
    "dev": {
      "command": "start-storybook"
    },
    "start": {
      "command": "start-storybook"
    },
    "build": {
      "command": "build-storybook --output-dir dist",
      "outputs": [
        "{workspaceRoot}/{projectRoot}/dist"
      ]
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "lint-styles": {
      "executor": "@cbhq/mono-tasks:lint-styles"
    },
    "typecheck": {
      "command": "tsc --build --pretty --verbose"
    },
    "analyze": {
      "command": "build-storybook --output-dir dist",
      "env": {
        "ANALYZE": true
      }
    },
    "build-for-analyze": {
      "command": "build-storybook --output-dir dist",
      "outputs": [
        "{workspaceRoot}/{projectRoot}/dist"
      ],
      "env": {
        "ANALYZE": true,
        "ANALYZE_MODE_JSON": true
      },
      "dependsOn": [
        "^build"
      ],
      "options": {
        "cwd": "apps/storybook"
      }
    },
    "build-for-tests": {
      "command": "build-storybook --output-dir dist",
      "dependsOn": [
        "^build"
      ],
      "options": {
        "cwd": "apps/storybook"
      }
    },
    "a11y-web": {
      "command": "tsx ./scripts/run-a11y-tests.ts",
      "dependsOn": [
        "build-for-tests"
      ],
      "inputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "cwd": "apps/storybook"
      }
    },
    "percy": {
      "command": "tsx ./scripts/run-percy.ts",
      "dependsOn": [
        "build-for-tests"
      ],
      "options": {
        "cwd": "apps/storybook"
      }
    },
    "serve-storybook": {
      "command": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npx http-server /workdir/apps/storybook/dist --port 6006 --silent\" \"wait-on tcp:6006 && yarn workspace @cds/storybook test-storybook --index-json\"",
      "options": {
        "cwd": "apps/storybook"
      }
    },
    "storybook-e2e-test": {
      "command": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"nx run storybook:build && npx http-server /workdir/apps/storybook/dist --port 6006 --silent\" \"wait-on tcp:6006 && yarn workspace @cds/storybook test-storybook --index-json\"",
      "dependsOn": [
        "build-for-tests"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ],
      "options": {
        "cwd": "apps/storybook"
      }
    },
    "analyze-bundle": {
      "command": "tsx ./scripts/analyze-bundle.ts",
      "dependsOn": [
        "build-for-analyze"
      ],
      "options": {
        "cwd": "apps/storybook"
      }
    },
    "profile-exports": {
      "command": "tsx ./scripts/profile-exports.js",
      "dependsOn": [
        "^build"
      ],
      "options": {
        "cwd": "apps/storybook"
      }
    }
  }
}
