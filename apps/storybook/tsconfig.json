{
  "extends": "../../tsconfig.projectOptions.json",
  "compilerOptions": {
    "outDir": "../../.nx/dts/apps/storybook",
    "rootDir": "./"
    /** 
     * Compiler paths are not respected by storybook. So if any module alias is not working
     * you need to add it to `config.resolve.alias` in main.js.
     **/
  },
  "references": [
    {
      "path": "../../packages/icons"
    },
    {
      "path": "../../packages/web"
    },
    {
      "path": "../../packages/fonts"
    },
    {
      "path": "../../packages/illustrations"
    },
    {
      "path": "../../packages/cds-web-overlays"
    },
    {
      "path": "../../packages/web-visualization"
    }
  ],
  "exclude": [
    "babel.config.js"
  ]
}
