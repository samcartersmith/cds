{
  "name": "figma-icons-plugin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/figma-icons-plugin",
  "projectType": "application",
  "tags": [],
  "targets": {
    "watch": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/figma-icons-plugin",
        "commands": [
          "esbuild ./src/plugin.ts --bundle --outfile=lib/plugin.js --watch",
          "vite build --watch"
        ],
        "parallel": true
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/lib"
      ],
      "options": {
        "cwd": "apps/figma-icons-plugin",
        "commands": [
          "esbuild ./src/plugin.ts --bundle --outfile=lib/plugin.js",
          "vite build"
        ],
        "parallel": true
      }
    },
    "format": {
      "executor": "@cbhq/mono-tasks:format"
    },
    "lint": {
      "executor": "@cbhq/mono-tasks:lint"
    },
    "test": {
      "executor": "@cbhq/mono-tasks:test"
    },
    "typecheck": {
      "executor": "@cbhq/mono-tasks:typecheck"
    }
  }
}
