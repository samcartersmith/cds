+function isProtectedBase() {
+  const branch = process.env.BUILDKITE_BRANCH ?? '';
+
+  if (branch === 'master' || branch === 'develop' || branch.startsWith('release-') || branch.startsWith('alpha-')) {
+    return true;
+  }
+
+  return false;
+}
+
+function getBaseBranch() {
+  let base = process.env.BUILDKITE_PULL_REQUEST_BASE_BRANCH;
+
+  if (base === '' || !base) {
+    base = process.env.OVERRIDE_BUILDKITE_PULL_REQUEST_BASE_BRANCH ?? 'master';
+  }
+
+  return base;
+}
+
