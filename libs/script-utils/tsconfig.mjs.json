{
  "extends": "../../tsconfig.buildOptions.json",
  "compilerOptions": {
    "outDir": "mjs",
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "**/*.spec.*",
    "**/*.stories.*",
    "**/*.test.*",
    "**/__fixtures__/**",
    "**/__mocks__/**",
    "**/__stories__/**",
    "**/__tests__/**"
  ]
}
