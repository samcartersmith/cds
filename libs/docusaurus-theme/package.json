{
  "name": "@cbhq/docusaurus-theme",
  "version": "0.0.0",
  "private": true,
  "description": "CDS Docusaurus theme",
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "libs/docusaurus-theme"
  },
  "type": "commonjs",
  "main": "./lib/index.js",
  "types": "./dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dts/index.d.ts",
      "default": "./lib/index.js"
    },
    "./types": {
      "types": "./types.d.ts"
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "default": "./lib/*.js"
    }
  },
  "files": [
    "cjs",
    "dts",
    "types.d.ts",
    "CHANGELOG"
  ],
  "peerDependencies": {
    "@cbhq/cds-common": "workspace:^",
    "@cbhq/cds-web": "workspace:^",
    "@cbhq/docusaurus-plugin-docgen": "workspace:^",
    "@cbhq/docusaurus-plugin-kbar": "workspace:^",
    "kbar": "^0.1.0-beta.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "@docusaurus/core": "2.0.0-beta.18",
    "@docusaurus/theme-classic": "2.0.0-beta.18",
    "@docusaurus/theme-common": "2.0.0-beta.18",
    "@docusaurus/theme-live-codeblock": "2.0.0-beta.18",
    "schedulely": "^0.0.31"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@cbhq/cds-common": "workspace:^",
    "@cbhq/cds-web": "workspace:^",
    "@docusaurus/module-type-aliases": "2.0.0-beta.18",
    "@joshcena/docusaurus-plugin-utils": "^0.1.3",
    "@types/postcss-preset-env": "^6.7.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^7.2.1",
    "nodemon": "^2.0.16",
    "postcss": "^8.4.14",
    "postcss-preset-env": "^7.7.1"
  }
}
