{
  "name": "@cbhq/docusaurus-preset",
  "version": "0.0.0",
  "description": "CDS Docusaurus preset",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git@github.cbhq.net:frontend/cds.git",
    "directory": "libs/docusaurus-preset"
  },
  "type": "commonjs",
  "main": "./cjs/index.js",
  "types": "./dts/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dts/index.d.ts",
      "default": "./cjs/index.js"
    },
    "./*": {
      "types": "./dts/*.d.ts",
      "default": "./cjs/*.js"
    }
  },
  "files": [
    "cjs",
    "dts",
    "CHANGELOG"
  ],
  "peerDependencies": {
    "@cbhq/cds-common": "workspace:^"
  },
  "dependencies": {
    "@cbhq/docusaurus-plugin-docgen": "workspace:^",
    "@cbhq/docusaurus-plugin-kbar": "workspace:^",
    "@cbhq/docusaurus-theme": "workspace:^",
    "@docusaurus/preset-classic": "^3.6.3",
    "@docusaurus/theme-live-codeblock": "^3.6.3",
    "type-fest": "^2.19.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-react": "^7.18.6",
    "@babel/preset-typescript": "^7.18.6",
    "@docusaurus/types": "^3.6.3"
  }
}
